section_nginx_ctrl() {
    section_banner "nginx Control" ""
    echo -e "  ${BLUE}  1)${R}  Test configuration   ${DIM}(nginx -t)${R}"
    echo -e "  ${BLUE}  2)${R}  Reload               ${DIM}(graceful — keeps connections alive)${R}"
    echo -e "  ${BLUE}  3)${R}  Restart              ${DIM}(full restart via systemctl)${R}"
    echo -e "  ${BLUE}  4)${R}  Stop"
    echo -e "  ${BLUE}  5)${R}  Start"
    echo -e "  ${RED}  0)${R}  Back"
    blank; hr; blank

    local c; printf "  Select [0-5]: "; IFS= read -r c
    case "$c" in
        1)
            blank; nginx_test || true ;;
        2)
            blank
            if nginx_test &>/dev/null; then
                nginx_reload && ok "nginx reloaded." || err "Reload failed."
                _log "nginx reloaded"
            else
                err "Config test failed — not reloading."
            fi ;;
        3)
            confirm "Restart nginx?" && {
                systemctl restart nginx && ok "nginx restarted." || err "Restart failed."
                _log "nginx restarted"
            } ;;
        4)
            confirm "Stop nginx?" && {
                systemctl stop nginx && ok "nginx stopped." || err "Stop failed."
                _log "nginx stopped"
            } ;;
        5)
            systemctl start nginx && ok "nginx started." || err "Start failed."
            _log "nginx started" ;;
        0) return ;;
        *) warn "Invalid choice." ;;
    esac
    blank; read -rp "  Press Enter…" _
}

# ==============================================================================
#  MAIN MENU
# ==============================================================================
main_menu() {
    while true; do
        banner
        local running_str; running_str=$(nginx_is_running && echo "${GREEN}running${R}" || echo "${RED}stopped${R}")
        local nver; nver=$(state_get "NGINX_VERSION"); [[ -z "$nver" ]] && nver=$(nginx_version)
        local site_c; site_c=$(sites_list | grep -c '.' 2>/dev/null || echo 0)
        local cert_c; cert_c=$(certs_list | grep -c '.' 2>/dev/null || echo 0)

        echo -e "  ${DIM}nginx ${nver}  │  status: ${running_str}  │  sites: ${WHITE}${site_c}${R}${DIM}  │  certs: ${WHITE}${cert_c}${R}"
        blank; hr; blank

        echo -e "  ${BOLD}${CYAN}  1)${R}  nginx.conf Management      ${DIM}— workers, http, gzip, log formats${R}"
        echo -e "  ${BOLD}${CYAN}  2)${R}  Virtual Hosts              ${DIM}— create, enable, disable, delete${R}"
        echo -e "  ${BOLD}${CYAN}  3)${R}  SSL Certificates           ${DIM}— create, upload, inspect, expiry${R}"
        echo -e "  ${BOLD}${CYAN}  4)${R}  nginx Control              ${DIM}— test, reload, restart, stop, start${R}"
        echo -e "  ${BOLD}${CYAN}  5)${R}  System Status"
        echo -e "  ${RED}  0)${R}  Exit"
        blank; hr; blank

        local c; printf "  Select [0-5]: "; IFS= read -r c
        case "$c" in
            1) section_nginx_conf ;;
            2) section_sites ;;
            3) section_certs ;;
            4) section_nginx_ctrl ;;
            5) section_status ;;
            0)
                blank
                info "Exiting pngxconf."
                blank
                exit 0 ;;
            *) warn "Invalid choice." ;;
        esac
    done
}

# ==============================================================================
#  ENTRY POINT
# ==============================================================================
case "${1:-}" in
    -h|--help) show_help; exit 0 ;;
    "")
        require_root
        state_init
        first_run_check
        startup_check
        main_menu
        ;;
    *)
        err "Unknown argument: $1"
        echo "  Usage: pngxconf  |  pngxconf -h"
        exit 1
        ;;
esac
