_sites_list_show() {
    section_banner "Virtual Hosts — All Sites" ""
    local rows; rows=$(sites_list)
    if [[ -z "$rows" ]]; then
        info "No managed virtual hosts yet."
    else
        printf "  %-20s %-35s %-6s %-8s %s\n" "NAME" "SERVER_NAME" "PORT" "STATUS" "CONFIG FILE"
        hr
        while IFS='|' read -r name conf sn port cert key status ts; do
            local fexists="?"
            [[ -f "$conf" ]] && fexists="ok" || fexists="${RED}missing${R}"
            printf "  %-20s %-35s %-6s " "$name" "$sn" "$port"
            [[ "$status" == "enabled" ]] && printf "${GREEN}%-8s${R}" "$status" || printf "${YELLOW}%-8s${R}" "$status"
            printf " %s %b\n" "$(basename "$conf")" "$fexists"
        done <<< "$rows"
    fi
    blank; read -rp "  Press Enter…" _
}

_site_create() {
    section_banner "Create Virtual Host" "Config will be placed in ${NGINX_CONFD}/"

    local name sn listen_port proxy_pass ssl_enable
    ssl_enable="no"

    ask name "Site name (identifier, no spaces)" || return
    # sanitize
    name="${name//[^a-zA-Z0-9_-]/_}"

    if [[ -f "${NGINX_CONFD}/${name}.conf" ]]; then
        warn "Config ${NGINX_CONFD}/${name}.conf already exists."
        confirm "Overwrite?" || return
    fi

    blank
    echo -e "  ${BOLD}Site type:${R}"
    blank
    echo -e "  ${BLUE}  1)${R}  Reverse proxy          ${DIM}— forward to upstream IP:port${R}"
    echo -e "  ${BLUE}  2)${R}  Static site            ${DIM}— serve files from directory${R}"
    echo -e "  ${BLUE}  3)${R}  Reverse proxy + SSL    ${DIM}— HTTPS reverse proxy${R}"
    echo -e "  ${BLUE}  4)${R}  HTTP redirect to HTTPS ${DIM}— redirect only${R}"
    blank; hr; blank

    local stype; menu_pick stype "rp" "static" "rp_ssl" "redir" || return
    local stypes=("rp" "static" "rp_ssl" "redir"); stype="${stypes[$((stype-1))]}"

    blank
    ask sn "server_name (domain or IP, e.g. example.com)" || return
    ask listen_port "Listen port" "80" || return

    local conf_file="${NGINX_CONFD}/${name}.conf"
    local cert_path="" key_path="" upstream_addr="" static_root=""

    case "$stype" in
        rp|rp_ssl)
            local up_ip up_port
            ask up_ip "Upstream IP address" || return
            ask up_port "Upstream port" "3000" || return
            upstream_addr="${up_ip}:${up_port}"

            if [[ "$stype" == "rp_ssl" ]]; then
                ssl_enable="yes"
                listen_port="443"
                blank
                cert_path=$(_pick_cert_path "Select certificate (.crt/.pem)") || return
                key_path=$(_pick_key_path "Select private key (.key)") || return
            fi

            _write_rp_conf "$conf_file" "$sn" "$listen_port" "$upstream_addr" \
                           "$ssl_enable" "$cert_path" "$key_path" "$name"
            ;;
        static)
            ask static_root "Document root path" "/var/www/${name}" || return
            mkdir -p "$static_root"
            _write_static_conf "$conf_file" "$sn" "$listen_port" "$static_root"
            ;;
        redir)
            local redir_to
            ask redir_to "Redirect to URL" "https://${sn}" || return
            _write_redir_conf "$conf_file" "$sn" "$listen_port" "$redir_to"
            ;;
    esac

    # Register in DB
    site_add "$name" "$conf_file" "$sn" "$listen_port" "$cert_path" "$key_path" "enabled"

    blank; hr; blank
    ok "Virtual host '${name}' created: ${conf_file}"
    blank
    info "Testing nginx configuration…"
    blank
    if nginx_test; then
        blank
        if confirm "Reload nginx now?"; then
            nginx_reload && ok "nginx reloaded." || err "Reload failed."
        fi
    else
        err "nginx config test failed — check the generated file."
        warn "File: ${conf_file}"
    fi
    blank; read -rp "  Press Enter…" _
}

_write_rp_conf() {
    local conf="$1" sn="$2" port="$3" upstream="$4" ssl="$5" cert="$6" key="$7" uname="${8:-backend}"
    local up_name="${uname}_upstream"
    cat > "$conf" <<EOF
# pngxconf — reverse proxy — ${sn}
# Generated: $(date '+%Y-%m-%d %H:%M:%S')

upstream ${up_name} {
    server ${upstream};
    keepalive 32;
}

server {
    listen      ${port}$([ "$ssl" = "yes" ] && echo " ssl" || echo "");
    listen      [::]:${port}$([ "$ssl" = "yes" ] && echo " ssl" || echo "");
    server_name ${sn};

    server_tokens off;

EOF
    if [[ "$ssl" == "yes" ]]; then
        cat >> "$conf" <<EOF
    # ── SSL ──────────────────────────────────────────────────────────
    ssl_certificate         ${cert};
    ssl_certificate_key     ${key};
    ssl_protocols           TLSv1.2 TLSv1.3;
    ssl_ciphers             ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305;
    ssl_prefer_server_ciphers on;
    ssl_session_cache       shared:SSL:10m;
    ssl_session_timeout     1d;
    ssl_session_tickets     off;

EOF
    fi
    cat >> "$conf" <<EOF
    # ── Security headers ─────────────────────────────────────────────
    add_header X-Frame-Options         "SAMEORIGIN"                        always;
    add_header X-Content-Type-Options  "nosniff"                           always;
    add_header X-XSS-Protection        "1; mode=block"                     always;
    add_header Referrer-Policy         "strict-origin-when-cross-origin"   always;

    # ── Logging ──────────────────────────────────────────────────────
    access_log  /var/log/nginx/${sn}_access.log;
    error_log   /var/log/nginx/${sn}_error.log warn;

    # ── Proxy ────────────────────────────────────────────────────────
    location / {
        proxy_pass              http://${up_name};
        proxy_http_version      1.1;
        proxy_set_header        Host              \$host;
        proxy_set_header        X-Real-IP         \$remote_addr;
        proxy_set_header        X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header        X-Forwarded-Proto \$scheme;
        proxy_set_header        Connection        "";
        proxy_read_timeout      60s;
        proxy_connect_timeout   10s;
        proxy_send_timeout      60s;
        proxy_buffering         on;
        proxy_buffer_size       4k;
        proxy_buffers           8 4k;
    }
}
EOF
}

_write_static_conf() {
    local conf="$1" sn="$2" port="$3" root="$4"
    cat > "$conf" <<EOF
# pngxconf — static site — ${sn}
# Generated: $(date '+%Y-%m-%d %H:%M:%S')

server {
    listen      ${port};
    listen      [::]:${port};
    server_name ${sn};

    server_tokens off;

    root  ${root};
    index index.html index.htm;

    add_header X-Frame-Options        "SAMEORIGIN"                       always;
    add_header X-Content-Type-Options "nosniff"                          always;

    access_log  /var/log/nginx/${sn}_access.log;
    error_log   /var/log/nginx/${sn}_error.log warn;

    location / {
        try_files \$uri \$uri/ =404;
    }
}
EOF
}

_write_redir_conf() {
    local conf="$1" sn="$2" port="$3" target="$4"
    cat > "$conf" <<EOF
# pngxconf — redirect — ${sn}
# Generated: $(date '+%Y-%m-%d %H:%M:%S')

server {
    listen      ${port};
    listen      [::]:${port};
    server_name ${sn};
    server_tokens off;

    access_log  /var/log/nginx/${sn}_access.log;
    return 301  ${target}\$request_uri;
}
EOF
}

_pick_cert_path() {
    local hint="${1:-Select certificate}"
    blank
    echo -e "  ${BOLD}${hint}${R}"
    blank

    local certs_in_ssl=()
    if [[ -d "$NGINX_SSL_DIR" ]]; then
        while IFS= read -r -d '' f; do
            certs_in_ssl+=("$f")
        done < <(find "$NGINX_SSL_DIR" -maxdepth 3 -type f \( -name "*.crt" -o -name "*.pem" -o -name "*.cer" \) -print0 2>/dev/null || true)
    fi

    local i=1
    for f in "${certs_in_ssl[@]}"; do
        echo -e "  ${BLUE}  ${i})${R}  ${f}"
        (( i++ ))
    done
    local total=${#certs_in_ssl[@]}
    echo -e "  ${BLUE}  $((total+1)))${R}  Enter path manually"
    blank; hr; blank

    local c; printf "  Select [1-%d]  (b = back): " "$((total+1))"; IFS= read -r c
    if [[ "${c,,}" == "b" ]]; then NAV="back"; echo ""; return 1; fi
    if [[ "$c" =~ ^[0-9]+$ ]] && (( c >= 1 && c <= total )); then
        echo "${certs_in_ssl[$((c-1))]}"; return 0
    elif (( c == total+1 )); then
        local manual_path
        ask manual_path "Full path to certificate" || { echo ""; return 1; }
        echo "$manual_path"; return 0
    fi
    echo ""; return 1
}

