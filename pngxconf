        blank
        echo -e "  ${BOLD}${WHITE}Subject Alternative Names:${R}"
        openssl x509 -noout -ext subjectAltName -in "$cfile" 2>/dev/null || true
        blank
        echo -e "  ${BOLD}${WHITE}Serial:${R}"
