        echo -e "  ${BLUE}  2)${R}  Create new virtual host"
        echo -e "  ${BLUE}  3)${R}  View virtual host config"
        echo -e "  ${BLUE}  4)${R}  Enable / disable virtual host"
        echo -e "  ${BLUE}  5)${R}  Delete virtual host"
        echo -e "  ${BLUE}  6)${R}  Check all site configs"
        echo -e "  ${RED}  0)${R}  Back to main menu"
        blank; hr; blank

        local c; printf "  Select [0-6]: "; IFS= read -r c
        case "$c" in
            1) _sites_list_show ;;
