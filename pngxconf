_site_toggle() {
    section_banner "Enable / Disable Virtual Host" ""
    local rows; rows=$(sites_list)
    [[ -z "$rows" ]] && { info "No sites."; read -rp "  Press Enter…" _; return; }

    local i=1; declare -a names=()
    while IFS='|' read -r name _ sn _ _ _ status _; do
        local badge; [[ "$status" == "enabled" ]] && badge="${GREEN}enabled${R}" || badge="${YELLOW}disabled${R}"
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${sn})${R}  — ${badge}"
        names+=("$name"); (( i++ ))
    done <<< "$rows"
    blank; hr; blank

    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"
    local cfile; cfile=$(site_get_field "$chosen" 2)
    local cur_status; cur_status=$(site_get_field "$chosen" 7)

    if [[ "$cur_status" == "enabled" ]]; then
        # disable: rename .conf to .conf.disabled
        if [[ -f "$cfile" ]]; then
            mv "$cfile" "${cfile}.disabled"
            ok "Disabled: ${cfile} → ${cfile}.disabled"
            _log "site disabled: ${chosen}"
        fi
        # update DB
        sed -i "s|^${chosen}|\(.*\)|\(.*\)|\(.*\)|\(.*\)|\(.*\)|\(.*\)|enabled||\1|\2|\3|\4|\5|\6|disabled||" "${PNGX_SITES_DB}" 2>/dev/null || \
        awk -F'|' -v name="$chosen" 'BEGIN{OFS="|"} $1==name{$7="disabled"} {print}' "${PNGX_SITES_DB}" > "${PNGX_SITES_DB}.tmp" && \
        mv "${PNGX_SITES_DB}.tmp" "${PNGX_SITES_DB}"
    else
        # enable: rename back
        if [[ -f "${cfile}.disabled" ]]; then
            mv "${cfile}.disabled" "$cfile"
            ok "Enabled: ${cfile}"
            _log "site enabled: ${chosen}"
        elif [[ -f "$cfile" ]]; then
            ok "Config file already exists: ${cfile}"
        else
            err "Config file not found: ${cfile}"
        fi
        awk -F'|' -v name="$chosen" 'BEGIN{OFS="|"} $1==name{$7="enabled"} {print}' "${PNGX_SITES_DB}" > "${PNGX_SITES_DB}.tmp" && \
        mv "${PNGX_SITES_DB}.tmp" "${PNGX_SITES_DB}"
    fi

    blank
    if confirm "Reload nginx?"; then
        nginx_reload && ok "nginx reloaded." || err "Reload failed."
    fi
    blank; read -rp "  Press Enter…" _
}

_site_delete() {
