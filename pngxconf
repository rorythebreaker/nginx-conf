#!/usr/bin/env bash
# ==============================================================================
#  pngxconf — Nginx Management System
#  Install: sudo bash install.sh
#  Usage  : pngxconf   |   pngxconf -h
#  Version: 1.2
# ==============================================================================
set -uo pipefail

# ==============================================================================
#  Paths & constants
# ==============================================================================
readonly PNGX_STATE_DIR="/var/lib/pngxconf"
readonly PNGX_STATE_FILE="${PNGX_STATE_DIR}/state.conf"
readonly PNGX_SITES_DB="${PNGX_STATE_DIR}/sites.db"
readonly PNGX_CERTS_DB="${PNGX_STATE_DIR}/certs.db"
readonly PNGX_LOG="${PNGX_STATE_DIR}/pngxconf.log"
readonly PNGX_SSL_WIZARD_DEFAULT="/usr/local/lib/pngxconf/ssl-wizard.sh"

readonly NGINX_CONF="/etc/nginx/nginx.conf"
readonly NGINX_CONF_BAK_DIR="/etc/nginx/pngxconf-backups"
readonly NGINX_CONFD="/etc/nginx/conf.d"
readonly NGINX_SSL_DIR="/etc/nginx/ssl"

readonly PNGX_VERSION="1.2"

# ==============================================================================
#  Colors
# ==============================================================================
R=$'\033[0m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
RED=$'\033[38;2;210;65;65m'
GREEN=$'\033[38;2;80;200;120m'
YELLOW=$'\033[38;2;230;185;55m'
CYAN=$'\033[38;2;75;200;215m'
BLUE=$'\033[38;2;70;145;235m'
MAGENTA=$'\033[38;2;190;105;235m'
WHITE=$'\033[38;2;235;235;235m'

# ==============================================================================
#  Logging
# ==============================================================================
info()  { echo -e "${CYAN}  ●${R} $*"; }
ok()    { echo -e "${GREEN}  ✔${R} $*"; }
warn()  { echo -e "${YELLOW}  ⚠${R} $*"; }
blank() { echo ""; }
hr()    { echo -e "${DIM}  $(printf '%.0s─' {1..62})${R}"; }

_log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "${PNGX_LOG}" 2>/dev/null || true; }

# Error output that ALWAYS pauses — never proceeds without user acknowledgement
err() {
    echo "" >&2
    echo -e "${RED}  ✖ ERROR:${R} $*" >&2
    _log "ERROR: $*"
    # Pause unless we're in non-interactive context (e.g. piped input)
    if [[ -t 0 ]]; then
        echo "" >&2
        echo -e "  ${YELLOW}── Press any key to acknowledge ──${R}" >&2
        read -rsn1 _
    fi
}

# Fatal error — pause then exit
die() {
    err "$*"
    exit 1
}

# Used inside operations where a non-fatal error needs the user to read and press a key
err_pause() {
    echo "" >&2
    echo -e "${RED}  ✖${R} $*" >&2
    _log "ERROR: $*"
    if [[ -t 0 ]]; then
        echo "" >&2
        echo -e "  ${YELLOW}── Press any key to continue ──${R}" >&2
        read -rsn1 _
    fi
}

# ==============================================================================
#  Root check
# ==============================================================================
require_root() {
    [[ $EUID -eq 0 ]] || die "pngxconf must be run as root. Try: sudo pngxconf"
}

# ==============================================================================
#  Help
# ==============================================================================
show_help() {
    cat <<EOF

${BOLD}${BLUE}pngxconf${R} ${DIM}v${PNGX_VERSION}${R} — Nginx Management System

${BOLD}Usage:${R}
  pngxconf          Launch interactive TUI
  pngxconf -h       Show this help

${BOLD}Navigation:${R}
  1-9       select menu item
  0         back / exit
  b         back (in prompts and lists)
  Enter     confirm / accept default
  y / n     yes / no

${BOLD}Features:${R}
  • Manage virtual hosts in ${NGINX_CONFD}/
  • Create / edit reverse-proxy and static configs
  • Auto-generate self-signed certs when creating SSL hosts
  • Automatic HTTP→HTTPS redirect blocks
  • Manage SSL certificates in ${NGINX_SSL_DIR}/<domain>/
  • Edit nginx.conf with timestamped backups
  • Integrate ssl-wizard.sh for Let's Encrypt and self-signed
  • Firewall awareness for ACME HTTP-01 challenge

${BOLD}File layout:${R}
  ${NGINX_CONF}                main config
  ${NGINX_CONFD}/*.conf          virtual hosts
  ${NGINX_SSL_DIR}/<domain>/       per-domain certs
  ${PNGX_STATE_DIR}/             pngxconf state

${BOLD}Requires:${R}  bash 4+, nginx, openssl, root

EOF
}

# ==============================================================================
#  State helpers
# ==============================================================================
state_init() {
    mkdir -p "${PNGX_STATE_DIR}" "${NGINX_CONF_BAK_DIR}"
    touch "${PNGX_STATE_FILE}" "${PNGX_SITES_DB}" "${PNGX_CERTS_DB}" "${PNGX_LOG}"
    chmod 700 "${PNGX_STATE_DIR}"
    chmod 600 "${PNGX_STATE_FILE}" "${PNGX_SITES_DB}" "${PNGX_CERTS_DB}"

    if [[ -d /etc/nginx ]]; then
        mkdir -p "${NGINX_CONFD}"
        [[ ! -d "${NGINX_SSL_DIR}" ]] && { mkdir -p "${NGINX_SSL_DIR}"; chmod 700 "${NGINX_SSL_DIR}"; }
    fi
}

state_get() {
    grep -m1 "^${1}=" "${PNGX_STATE_FILE}" 2>/dev/null | cut -d= -f2-
}

state_set() {
    local key="$1" val="$2"
    local tmp; tmp=$(mktemp)
    grep -v "^${key}=" "${PNGX_STATE_FILE}" > "$tmp" 2>/dev/null || true
    echo "${key}=${val}" >> "$tmp"
    mv "$tmp" "${PNGX_STATE_FILE}"
    chmod 600 "${PNGX_STATE_FILE}"
}

# sites DB: name|conf_path|server_name|listen_port|ssl_cert|ssl_key|status|created|type|upstream
# Field 9 (type): rp | rp_ssl | static | redir
# Field 10 (upstream): ip:port for rp/rp_ssl, empty otherwise
site_add() {
    local name="$1" conf="$2" sn="$3" port="$4" cert="${5:-}" key="${6:-}" \
          status="${7:-enabled}" stype="${8:-rp}" upstream="${9:-}"
    local ts; ts=$(date '+%Y-%m-%d %H:%M:%S')
    site_remove "$name" 2>/dev/null || true
    echo "${name}|${conf}|${sn}|${port}|${cert}|${key}|${status}|${ts}|${stype}|${upstream}" >> "${PNGX_SITES_DB}"
    chmod 600 "${PNGX_SITES_DB}"
    _log "site_add name=${name} type=${stype}"
}

site_remove() {
    local name="$1"
    local tmp; tmp=$(mktemp)
    grep -v "^${name}|" "${PNGX_SITES_DB}" > "$tmp" 2>/dev/null || true
    mv "$tmp" "${PNGX_SITES_DB}"
    chmod 600 "${PNGX_SITES_DB}"
    _log "site_remove name=${name}"
}

site_set_status() {
    local name="$1" new_status="$2"
    local tmp; tmp=$(mktemp)
    awk -F'|' -v n="$name" -v s="$new_status" 'BEGIN{OFS="|"} $1==n{$7=s} {print}' \
        "${PNGX_SITES_DB}" > "$tmp"
    mv "$tmp" "${PNGX_SITES_DB}"
    chmod 600 "${PNGX_SITES_DB}"
}

site_update_field() {
    # site_update_field <name> <field_num> <value>
    local name="$1" field="$2" value="$3"
    local tmp; tmp=$(mktemp)
    awk -F'|' -v n="$name" -v f="$field" -v v="$value" \
        'BEGIN{OFS="|"} $1==n{$f=v} {print}' \
        "${PNGX_SITES_DB}" > "$tmp"
    mv "$tmp" "${PNGX_SITES_DB}"
    chmod 600 "${PNGX_SITES_DB}"
}

site_get_field() {
    grep "^${1}|" "${PNGX_SITES_DB}" 2>/dev/null | head -1 | cut -d'|' -f"${2}"
}

sites_list() {
    grep -v '^#' "${PNGX_SITES_DB}" 2>/dev/null | grep -v '^$' || true
}

sites_count() { sites_list | wc -l | tr -d ' '; }

# certs DB
cert_add() {
    local name="$1" domain="$2" cert="$3" key="$4" chain="${5:-}" type="${6:-manual}"
    cert_remove "$name" 2>/dev/null || true
    local ts; ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "${name}|${domain}|${cert}|${key}|${chain}|${type}|${ts}" >> "${PNGX_CERTS_DB}"
    chmod 600 "${PNGX_CERTS_DB}"
    _log "cert_add name=${name} domain=${domain}"
}

cert_remove() {
    local tmp; tmp=$(mktemp)
    grep -v "^${1}|" "${PNGX_CERTS_DB}" > "$tmp" 2>/dev/null || true
    mv "$tmp" "${PNGX_CERTS_DB}"
    chmod 600 "${PNGX_CERTS_DB}"
}

cert_get_field() {
    grep "^${1}|" "${PNGX_CERTS_DB}" 2>/dev/null | head -1 | cut -d'|' -f"${2}"
}

certs_list() {
    grep -v '^#' "${PNGX_CERTS_DB}" 2>/dev/null | grep -v '^$' || true
}

certs_count() { certs_list | wc -l | tr -d ' '; }

# ==============================================================================
#  Input helpers
# ==============================================================================
NAV=""

ask() {
    local -n _ref=$1
    local prompt="$2"
    local default="${3:-}"
    local disp_def=""
    [[ -n "$default" ]] && disp_def=" ${DIM}[${default}]${R}"
    while true; do
        printf "  %s%s  ${DIM}(b = back)${R}: " "$prompt" "$disp_def"
        IFS= read -r _ref
        if [[ "${_ref,,}" == "b" ]]; then NAV="back"; return 1; fi
        [[ -z "$_ref" && -n "$default" ]] && _ref="$default"
        [[ -n "$_ref" ]] && { NAV=""; return 0; }
        warn "Value cannot be empty."
    done
}

ask_optional() {
    local -n _oref=$1
    local prompt="$2"
    printf "  %s  ${DIM}(b = back, Enter = skip)${R}: " "$prompt"
    IFS= read -r _oref
    if [[ "${_oref,,}" == "b" ]]; then NAV="back"; _oref=""; return 1; fi
    NAV=""; return 0
}

menu_pick() {
    local -n _mp=$1; shift
    local max=$#
    while true; do
        printf "  Select [1-%d]  ${DIM}(b = back)${R}: " "$max"
        IFS= read -r _mp
        if [[ "${_mp,,}" == "b" ]]; then NAV="back"; return 1; fi
        if [[ "$_mp" =~ ^[0-9]+$ ]] && (( _mp >= 1 && _mp <= max )); then
            NAV=""; return 0
        fi
        warn "Invalid choice — enter a number between 1 and ${max}."
    done
}

menu_choice() {
    local -n _mc=$1
    local prompt="$2"
    local min="$3" max="$4"
    while true; do
        printf "  %s [${min}-${max}]  ${DIM}(b = back)${R}: " "$prompt"
        IFS= read -r _mc
        if [[ "${_mc,,}" == "b" ]]; then NAV="back"; return 1; fi
        if [[ "$_mc" =~ ^[0-9]+$ ]] && (( _mc >= min && _mc <= max )); then
            NAV=""; return 0
        fi
        warn "Invalid choice — enter a number between ${min} and ${max} (or 'b' to go back)."
    done
}

confirm() {
    local ans
    printf "  %s [y/N]: " "$1"
    IFS= read -r ans
    [[ "${ans,,}" == "y" ]]
}

pause() { blank; read -rp "  Press Enter to continue…" _; }

clear_screen() { printf '\033[2J\033[H'; }

# ==============================================================================
#  Banner
# ==============================================================================
banner() {
    clear_screen
    echo ""
    echo -e "  ${BOLD}${BLUE}╔══════════════════════════════════════════════════════════╗${R}"
    echo -e "  ${BOLD}${BLUE}║${R}  ${BOLD}${WHITE}pngxconf${R} ${DIM}v${PNGX_VERSION}${R}  ${DIM}│${R}  ${CYAN}Nginx Management System${R}          ${BOLD}${BLUE}║${R}"
    echo -e "  ${BOLD}${BLUE}╚══════════════════════════════════════════════════════════╝${R}"
    echo ""
}

section_banner() {
    banner
    echo -e "  ${BOLD}${CYAN}$1${R}"
    [[ -n "${2:-}" ]] && echo -e "  ${DIM}$2${R}"
    hr; blank
}

# ==============================================================================
#  nginx helpers
# ==============================================================================
nginx_bin() {
    local b
    for b in nginx /usr/sbin/nginx /usr/local/sbin/nginx /usr/bin/nginx; do
        if command -v "$b" &>/dev/null; then echo "$b"; return 0; fi
        [[ -x "$b" ]] && { echo "$b"; return 0; }
    done
    echo ""
    return 1
}

nginx_version() {
    local b; b=$(nginx_bin)
    [[ -z "$b" ]] && { echo "not found"; return; }
    "$b" -v 2>&1 | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1
}

nginx_test() {
    local b; b=$(nginx_bin)
    if [[ -z "$b" ]]; then err_pause "nginx binary not found"; return 1; fi
    "$b" -t 2>&1
}

nginx_test_quiet() {
    local b; b=$(nginx_bin)
    [[ -z "$b" ]] && return 1
    "$b" -t 2>&1
}

nginx_reload() {
    local b; b=$(nginx_bin)
    [[ -z "$b" ]] && { err_pause "nginx binary not found"; return 1; }
    if systemctl is-active --quiet nginx 2>/dev/null; then
        systemctl reload nginx
    else
        "$b" -s reload
    fi
}

nginx_is_running() {
    systemctl is-active --quiet nginx 2>/dev/null && return 0
    pgrep -x nginx &>/dev/null && return 0
    return 1
}

# ==============================================================================
#  Firewall check (for ACME HTTP-01)
# ==============================================================================
check_firewall_port80() {
    # Returns 0 if port 80 looks reachable, 1 if blocked
    if command -v ufw &>/dev/null && ufw status 2>/dev/null | grep -qi 'active'; then
        if ufw status 2>/dev/null | grep -qE '^80(/tcp)?\s+ALLOW'; then
            return 0
        fi
        return 1
    fi
    if command -v firewall-cmd &>/dev/null && systemctl is-active --quiet firewalld 2>/dev/null; then
        if firewall-cmd --list-ports 2>/dev/null | grep -q '80/tcp' || \
           firewall-cmd --list-services 2>/dev/null | grep -qw 'http'; then
            return 0
        fi
        return 1
    fi
    # No active firewall manager or no rules — assume open
    return 0
}

firewall_check_section() {
    section_banner "FIREWALL CHECK" "Verifies port 80 is reachable for acme.sh HTTP-01"
    local fw_active=""
    local issues=0

    if command -v ufw &>/dev/null; then
        if ufw status 2>/dev/null | grep -qi 'active'; then
            fw_active="ufw"
            info "ufw is active"
            if ufw status 2>/dev/null | grep -qE '^80(/tcp)?\s+ALLOW'; then
                ok "ufw — port 80 OPEN"
            else
                warn "ufw — port 80 is NOT allowed"
                issues=$((issues+1))
                if confirm "Open port 80 in ufw?"; then
                    ufw allow 80/tcp && ok "Port 80 opened" || err_pause "ufw allow failed"
                fi
            fi
            if ufw status 2>/dev/null | grep -qE '^443(/tcp)?\s+ALLOW'; then
                ok "ufw — port 443 OPEN"
            else
                warn "ufw — port 443 is NOT allowed"
                if confirm "Open port 443 in ufw?"; then
                    ufw allow 443/tcp && ok "Port 443 opened" || err_pause "ufw allow failed"
                fi
            fi
        fi
    fi

    if command -v firewall-cmd &>/dev/null; then
        if systemctl is-active --quiet firewalld 2>/dev/null; then
            fw_active="${fw_active:+${fw_active}, }firewalld"
            info "firewalld is active"
            local zone; zone=$(firewall-cmd --get-default-zone 2>/dev/null)
            if firewall-cmd --list-ports 2>/dev/null | grep -q '80/tcp' || \
               firewall-cmd --list-services 2>/dev/null | grep -qw 'http'; then
                ok "firewalld — port 80 OPEN (zone: ${zone})"
            else
                warn "firewalld — port 80 NOT open"
                issues=$((issues+1))
                if confirm "Open port 80 and 443 in firewalld?"; then
                    firewall-cmd --permanent --add-service=http && \
                    firewall-cmd --permanent --add-service=https && \
                    firewall-cmd --permanent --add-port=80/tcp && \
                    firewall-cmd --permanent --add-port=443/tcp && \
                    firewall-cmd --reload && ok "firewalld updated" || err_pause "firewall-cmd failed"
                fi
            fi
        fi
    fi

    if [[ -z "$fw_active" ]] && command -v iptables &>/dev/null; then
        info "iptables active (no ufw/firewalld manager)"
        if iptables -L INPUT -n 2>/dev/null | grep -qE 'dpt:80\s.*ACCEPT'; then
            ok "iptables — port 80 has ACCEPT rule"
        else
            warn "iptables — no explicit ACCEPT for port 80"
            echo "  ${DIM}If default policy is DROP, acme.sh HTTP-01 will fail${R}"
            issues=$((issues+1))
        fi
    fi

    if [[ -z "$fw_active" ]] && ! command -v iptables &>/dev/null; then
        info "No firewall management tool detected — ports unrestricted"
    fi

    blank
    if (( issues > 0 )); then
        warn "${issues} potential firewall issue(s)"
        echo -e "  ${DIM}acme.sh HTTP-01 challenge requires port 80 reachable from internet${R}"
    else
        ok "Firewall check passed."
    fi
    pause
}

# ==============================================================================
#  Self-signed cert generation
# ==============================================================================
generate_self_signed_cert() {
    # Args: domain
    # Creates /etc/nginx/ssl/<domain>/<domain>.{crt,key}
    # Echoes cert_path and key_path via globals
    local domain="$1"
    local dest_dir="${NGINX_SSL_DIR}/${domain}"
    local cert_path="${dest_dir}/${domain}.crt"
    local key_path="${dest_dir}/${domain}.key"

    mkdir -p "$dest_dir"
    chmod 700 "$dest_dir"

    info "Generating self-signed certificate for ${domain}…"

    # Generate RSA 2048 self-signed cert valid for 825 days (Apple max)
    # SAN includes domain and *.<domain>
    local subj="/CN=${domain}/O=pngxconf self-signed"
    local san="DNS:${domain},DNS:*.${domain}"

    # If domain is IP, use IP SAN instead
    if [[ "$domain" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        san="IP:${domain}"
    fi

    local openssl_log="/tmp/pngxconf_openssl_$$.log"
    if openssl req -x509 -newkey rsa:2048 -nodes \
        -keyout "$key_path" -out "$cert_path" \
        -days 825 -subj "$subj" \
        -addext "subjectAltName=${san}" \
        > "$openssl_log" 2>&1
    then
        chmod 644 "$cert_path"
        chmod 600 "$key_path"
        ok "Self-signed cert created:"
        echo -e "    ${DIM}cert:${R} ${cert_path}"
        echo -e "    ${DIM}key :${R} ${key_path}"
        # Register in DB so it appears in cert lists
        local cert_name="${domain}_selfsigned"
        cert_add "$cert_name" "$domain" "$cert_path" "$key_path" "" "self-signed"
        rm -f "$openssl_log"
        # Set globals for caller
        GEN_CERT_PATH="$cert_path"
        GEN_KEY_PATH="$key_path"
        return 0
    else
        err_pause "openssl failed to generate certificate. Details: $(cat "$openssl_log")"
        rm -f "$openssl_log"
        return 1
    fi
}

# ==============================================================================
#  FIRST-RUN CHECK
# ==============================================================================
first_run_check() {
    local already; already=$(state_get "FIRST_RUN_DONE")
    [[ "$already" == "1" ]] && return 0

    section_banner "FIRST RUN — System Check" "Verifying nginx installation and environment"

    local issues=0

    local nbin; nbin=$(nginx_bin)
    if [[ -n "$nbin" ]]; then
        local nver; nver=$(nginx_version)
        ok "nginx binary     : ${nbin}  (${nver})"
        state_set "NGINX_BIN" "$nbin"
        state_set "NGINX_VERSION" "$nver"
    else
        echo -e "  ${RED}  ✖${R} nginx binary     : NOT FOUND"
        blank
        warn "Install nginx via your package manager, e.g.:"
        echo -e "  ${DIM}Debian/Ubuntu :${R}  apt install nginx"
        echo -e "  ${DIM}RHEL/Rocky    :${R}  dnf install nginx"
        echo -e "  ${DIM}Arch          :${R}  pacman -S nginx"
        echo -e "  ${DIM}openSUSE      :${R}  zypper install nginx"
        issues=$((issues+1))
    fi

    [[ -f "$NGINX_CONF" ]] && ok "nginx.conf       : ${NGINX_CONF}" || { warn "nginx.conf       : not found"; issues=$((issues+1)); }

    if [[ -d "$NGINX_CONFD" ]]; then
        ok "conf.d           : ${NGINX_CONFD}"
    elif [[ -d /etc/nginx ]]; then
        mkdir -p "$NGINX_CONFD"
        ok "conf.d           : created ${NGINX_CONFD}"
    fi

    if [[ -d "$NGINX_SSL_DIR" ]]; then
        ok "ssl directory    : ${NGINX_SSL_DIR}"
    elif [[ -d /etc/nginx ]]; then
        mkdir -p "$NGINX_SSL_DIR"; chmod 700 "$NGINX_SSL_DIR"
        ok "ssl directory    : created ${NGINX_SSL_DIR}"
    fi

    command -v openssl &>/dev/null && ok "openssl          : $(openssl version | awk '{print $2}')" || \
        { warn "openssl          : not found"; issues=$((issues+1)); }

    local wpath=""
    for p in "$PNGX_SSL_WIZARD_DEFAULT" \
             "$(dirname "$(readlink -f "$0")")/ssl-wizard.sh" \
             "${PNGX_STATE_DIR}/ssl-wizard.sh"; do
        [[ -f "$p" ]] && { wpath="$p"; break; }
    done
    if [[ -n "$wpath" ]]; then
        ok "ssl-wizard.sh    : ${wpath}"
        state_set "SSL_WIZARD_PATH" "$wpath"
    else
        warn "ssl-wizard.sh    : not found"
        state_set "SSL_WIZARD_PATH" ""
    fi

    blank; hr; blank
    (( issues > 0 )) && warn "${issues} issue(s) found." || ok "All checks passed."
    pause

    state_set "FIRST_RUN_DONE" "1"
    state_set "FIRST_RUN_DATE" "$(date '+%Y-%m-%d %H:%M:%S')"
}

startup_check() {
    local warnings=0
    while IFS='|' read -r name conf _ _ cert key _ _ _ _; do
        [[ -z "$name" ]] && continue
        [[ ! -f "$conf" && ! -f "${conf}.disabled" ]] && { _log "WARN site '${name}' conf missing"; warnings=$((warnings+1)); }
        [[ -n "$cert" && ! -f "$cert" ]] && warnings=$((warnings+1))
        [[ -n "$key"  && ! -f "$key"  ]] && warnings=$((warnings+1))
    done < <(sites_list)
    while IFS='|' read -r name _ cert key _ _ _; do
        [[ -z "$name" ]] && continue
        [[ -n "$cert" && ! -f "$cert" ]] && warnings=$((warnings+1))
        [[ -n "$key"  && ! -f "$key"  ]] && warnings=$((warnings+1))
    done < <(certs_list)
    if (( warnings > 0 )); then
        warn "${warnings} file(s) referenced in DB are missing — see ${PNGX_LOG}"
        sleep 1
    fi
}

# ==============================================================================
#  nginx.conf section (unchanged from v1.1)
# ==============================================================================
section_nginx_conf() {
    while true; do
        section_banner "NGINX.CONF MANAGEMENT" "${NGINX_CONF}"

        local nver running
        nver=$(nginx_version)
        running=$(nginx_is_running && echo "running" || echo "stopped")
        echo -e "  ${DIM}nginx version :${R} ${WHITE}${nver}${R}"
        echo -e "  ${DIM}status        :${R} ${WHITE}${running}${R}"
        blank
        echo -e "  ${BLUE}  1)${R}  View current nginx.conf"
        echo -e "  ${BLUE}  2)${R}  Edit core worker settings"
        echo -e "  ${BLUE}  3)${R}  Edit events block settings"
        echo -e "  ${BLUE}  4)${R}  Edit http block global settings"
        echo -e "  ${BLUE}  5)${R}  Edit log formats"
        echo -e "  ${BLUE}  6)${R}  Edit gzip settings"
        echo -e "  ${BLUE}  7)${R}  Apply / reload nginx"
        echo -e "  ${BLUE}  8)${R}  Test nginx configuration"
        echo -e "  ${BLUE}  9)${R}  View change history"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank

        local c; menu_choice c "Select" 0 9 || return
        case "$c" in
            1) _nginx_conf_view ;;
            2) _nginx_conf_workers ;;
            3) _nginx_conf_events ;;
            4) _nginx_conf_http ;;
            5) _nginx_conf_logformat ;;
            6) _nginx_conf_gzip ;;
            7) _nginx_apply ;;
            8) _nginx_test_show ;;
            9) _nginx_conf_history ;;
            0) return ;;
        esac
    done
}

_nginx_conf_view() {
    section_banner "nginx.conf — Current Contents" ""
    if [[ ! -f "$NGINX_CONF" ]]; then
        err_pause "File not found: ${NGINX_CONF}"
    else
        cat -n "$NGINX_CONF" | head -120
        blank
        local lines; lines=$(wc -l < "$NGINX_CONF")
        (( lines > 120 )) && info "(${lines} total lines — showing first 120)"
    fi
    pause
}

_nginx_conf_backup() {
    local reason="${1:-manual}"
    [[ ! -f "$NGINX_CONF" ]] && return 1
    local bak="${NGINX_CONF_BAK_DIR}/nginx.conf.$(date +%Y%m%d_%H%M%S).${reason}"
    cp "$NGINX_CONF" "$bak"
    state_set "NGINX_CONF_LAST_BAK" "$bak"
    _log "nginx.conf backup: ${bak}"
    echo "$bak"
}

_nginx_conf_set_param() {
    local key="$1" val="$2" ctx="${3:-main}" reason="${4:-set_${1}}"
    [[ ! -f "$NGINX_CONF" ]] && { err_pause "nginx.conf not found"; return 1; }
    _nginx_conf_backup "$reason" >/dev/null
    if grep -qE "^\s*${key}(\s|;)" "$NGINX_CONF"; then
        sed -i "s|^\(\s*\)${key}\s[^;]*;|\1${key} ${val};|" "$NGINX_CONF"
    else
        sed -i "/^\s*${ctx}\s*{/a\\    ${key} ${val};" "$NGINX_CONF"
    fi
    state_set "NGINX_CONF_LAST_EDIT" "$(date '+%Y-%m-%d %H:%M:%S')"
    _log "nginx.conf set ${key}=${val}"
}

_nginx_conf_workers() {
    while true; do
        section_banner "nginx.conf — Worker Settings" "main context"
        local cur_proc cur_rlimit cur_user
        cur_proc=$(grep -m1 '^\s*worker_processes' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_rlimit=$(grep -m1 '^\s*worker_rlimit_nofile' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_user=$(grep -m1 '^\s*user\s' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        echo -e "  ${DIM}worker_processes    :${R} ${WHITE}${cur_proc:-auto}${R}"
        echo -e "  ${DIM}worker_rlimit_nofile:${R} ${WHITE}${cur_rlimit:-not set}${R}"
        echo -e "  ${DIM}user                :${R} ${WHITE}${cur_user:-nginx}${R}"
        blank
        echo -e "  ${BLUE}  1)${R}  Set worker_processes"
        echo -e "  ${BLUE}  2)${R}  Set worker_rlimit_nofile"
        echo -e "  ${BLUE}  3)${R}  Set user"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank
        local c; menu_choice c "Select" 0 3 || return
        case "$c" in
            1)
                blank
                echo "  1) auto  2) 1  3) 2  4) 4  5) 8"; blank; hr; blank
                local wc; menu_pick wc "auto" "1" "2" "4" "8" || continue
                local vals=("auto" "1" "2" "4" "8")
                _nginx_conf_set_param "worker_processes" "${vals[$((wc-1))]}" "main" "worker_processes"
                ok "worker_processes set to ${vals[$((wc-1))]}"
                state_set "NGINX_WORKER_PROCESSES" "${vals[$((wc-1))]}"; pause ;;
            2) local wrl; ask wrl "worker_rlimit_nofile" "65535" && \
               { _nginx_conf_set_param "worker_rlimit_nofile" "$wrl" "main"; ok "Set"; pause; } ;;
            3) local wu; ask wu "nginx user" "${cur_user:-nginx}" && \
               { _nginx_conf_set_param "user" "$wu" "main"; ok "Set"; pause; } ;;
            0) return ;;
        esac
    done
}

_nginx_conf_events() {
    while true; do
        section_banner "nginx.conf — Events Block" "events { }"
        local cur_conn cur_multi cur_meth
        cur_conn=$(grep -m1 '^\s*worker_connections' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_multi=$(grep -m1 '^\s*multi_accept' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_meth=$(grep -m1 '^\s*use\s' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        echo -e "  ${DIM}worker_connections :${R} ${WHITE}${cur_conn:-1024}${R}"
        echo -e "  ${DIM}multi_accept       :${R} ${WHITE}${cur_multi:-off}${R}"
        echo -e "  ${DIM}use                :${R} ${WHITE}${cur_meth:-epoll}${R}"
        blank
        echo -e "  ${BLUE}  1)${R}  Set worker_connections"
        echo -e "  ${BLUE}  2)${R}  Toggle multi_accept"
        echo -e "  ${BLUE}  3)${R}  Set use (epoll/kqueue/select)"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank
        local c; menu_choice c "Select" 0 3 || return
        case "$c" in
            1)
                blank; echo "  1) 512  2) 1024  3) 2048  4) 4096  5) 8192"; blank; hr; blank
                local wc; menu_pick wc "512" "1024" "2048" "4096" "8192" || continue
                local vals=("512" "1024" "2048" "4096" "8192")
                _nginx_conf_set_param "worker_connections" "${vals[$((wc-1))]}" "events"
                ok "Set"; state_set "NGINX_WORKER_CONNECTIONS" "${vals[$((wc-1))]}"; pause ;;
            2)
                local new_ma; new_ma=$([[ "$cur_multi" == "on" ]] && echo "off" || echo "on")
                _nginx_conf_set_param "multi_accept" "$new_ma" "events"
                ok "Set to ${new_ma}"; pause ;;
            3) local um; ask um "I/O method" "${cur_meth:-epoll}" && \
               { _nginx_conf_set_param "use" "$um" "events"; ok "Set"; pause; } ;;
            0) return ;;
        esac
    done
}

_nginx_conf_http() {
    while true; do
        section_banner "nginx.conf — HTTP Block" "http { }"
        local cur_st cur_kb cur_mb cur_sn cur_tcp cur_th
        cur_st=$(grep -m1 '^\s*server_tokens' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_kb=$(grep -m1 '^\s*keepalive_timeout' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_mb=$(grep -m1 '^\s*client_max_body_size' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_sn=$(grep -m1 '^\s*sendfile' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_tcp=$(grep -m1 '^\s*tcp_nopush' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_th=$(grep -m1 '^\s*types_hash_max_size' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')

        echo -e "  ${DIM}server_tokens        :${R} ${WHITE}${cur_st:-on}${R}"
        echo -e "  ${DIM}keepalive_timeout    :${R} ${WHITE}${cur_kb:-65}${R}"
        echo -e "  ${DIM}client_max_body_size :${R} ${WHITE}${cur_mb:-1m}${R}"
        echo -e "  ${DIM}sendfile             :${R} ${WHITE}${cur_sn:-on}${R}"
        echo -e "  ${DIM}tcp_nopush           :${R} ${WHITE}${cur_tcp:-off}${R}"
        echo -e "  ${DIM}types_hash_max_size  :${R} ${WHITE}${cur_th:-2048}${R}"
        blank
        echo -e "  ${BLUE}  1)${R}  Toggle server_tokens"
        echo -e "  ${BLUE}  2)${R}  Set keepalive_timeout"
        echo -e "  ${BLUE}  3)${R}  Set client_max_body_size"
        echo -e "  ${BLUE}  4)${R}  Toggle sendfile"
        echo -e "  ${BLUE}  5)${R}  Toggle tcp_nopush"
        echo -e "  ${BLUE}  6)${R}  Set types_hash_max_size"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank
        local c; menu_choice c "Select" 0 6 || return
        case "$c" in
            1) local n; n=$([[ "$cur_st" == "off" ]] && echo "on" || echo "off")
               _nginx_conf_set_param "server_tokens" "$n" "http"; ok "Set to $n"; pause ;;
            2) local v; ask v "keepalive_timeout" "${cur_kb:-65}" && \
               { _nginx_conf_set_param "keepalive_timeout" "$v" "http"; ok "Set"; pause; } ;;
            3) local v; ask v "client_max_body_size" "${cur_mb:-1m}" && \
               { _nginx_conf_set_param "client_max_body_size" "$v" "http"; ok "Set"; pause; } ;;
            4) local n; n=$([[ "$cur_sn" == "on" ]] && echo "off" || echo "on")
               _nginx_conf_set_param "sendfile" "$n" "http"; ok "Set to $n"; pause ;;
            5) local n; n=$([[ "$cur_tcp" == "on" ]] && echo "off" || echo "on")
               _nginx_conf_set_param "tcp_nopush" "$n" "http"; ok "Set to $n"; pause ;;
            6) local v; ask v "types_hash_max_size" "${cur_th:-2048}" && \
               { _nginx_conf_set_param "types_hash_max_size" "$v" "http"; ok "Set"; pause; } ;;
            0) return ;;
        esac
    done
}

_nginx_conf_logformat() {
    while true; do
        section_banner "nginx.conf — Log Formats" "http { }"
        info "Current log_format directives:"; blank
        local lf; lf=$(grep -A2 'log_format' "$NGINX_CONF" 2>/dev/null | head -30)
        [[ -n "$lf" ]] && echo "$lf" || echo -e "  ${DIM}none found${R}"
        blank; hr; blank
        echo -e "  ${BLUE}  1)${R}  Add combined_plus format"
        echo -e "  ${BLUE}  2)${R}  Add json format"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank
        local c; menu_choice c "Select" 0 2 || return
        case "$c" in
            1)
                if ! grep -q 'log_format combined_plus' "$NGINX_CONF" 2>/dev/null; then
                    _nginx_conf_backup "logformat_combined_plus" >/dev/null
                    sed -i '/^\s*http\s*{/a\    log_format combined_plus '"'"'$remote_addr - $remote_user [$time_local] "$request" $status $body_bytes_sent "$http_referer" "$http_user_agent" rt=$request_time urt=$upstream_response_time'"'"';' "$NGINX_CONF"
                    ok "combined_plus added"
                else
                    warn "Already present"
                fi
                pause ;;
            2)
                if ! grep -q 'log_format json' "$NGINX_CONF" 2>/dev/null; then
                    _nginx_conf_backup "logformat_json" >/dev/null
                    sed -i '/^\s*http\s*{/a\    log_format json escape=json '"'"'{"time":"$time_iso8601","ip":"$remote_addr","method":"$request_method","uri":"$request_uri","status":"$status","bytes":$body_bytes_sent,"rt":"$request_time"}'"'"';' "$NGINX_CONF"
                    ok "json added"
                else
                    warn "Already present"
                fi
                pause ;;
            0) return ;;
        esac
    done
}

_nginx_conf_gzip() {
    while true; do
        section_banner "nginx.conf — Gzip" "http { }"
        local cur_gz cur_lvl cur_min cur_vary cur_prox
        cur_gz=$(grep -m1 '^\s*gzip\s' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_lvl=$(grep -m1 '^\s*gzip_comp_level' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_min=$(grep -m1 '^\s*gzip_min_length' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_vary=$(grep -m1 '^\s*gzip_vary' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        cur_prox=$(grep -m1 '^\s*gzip_proxied' "$NGINX_CONF" 2>/dev/null | awk '{print $2}' | tr -d ';')
        echo -e "  ${DIM}gzip            :${R} ${WHITE}${cur_gz:-off}${R}"
        echo -e "  ${DIM}gzip_comp_level :${R} ${WHITE}${cur_lvl:-6}${R}"
        echo -e "  ${DIM}gzip_min_length :${R} ${WHITE}${cur_min:-1024}${R}"
        echo -e "  ${DIM}gzip_vary       :${R} ${WHITE}${cur_vary:-off}${R}"
        echo -e "  ${DIM}gzip_proxied    :${R} ${WHITE}${cur_prox:-off}${R}"
        blank
        echo -e "  ${BLUE}  1)${R}  Toggle gzip"
        echo -e "  ${BLUE}  2)${R}  Set gzip_comp_level"
        echo -e "  ${BLUE}  3)${R}  Set gzip_min_length"
        echo -e "  ${BLUE}  4)${R}  Toggle gzip_vary"
        echo -e "  ${BLUE}  5)${R}  Set gzip_proxied"
        echo -e "  ${BLUE}  6)${R}  Apply recommended"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank
        local c; menu_choice c "Select" 0 6 || return
        case "$c" in
            1) local n; n=$([[ "$cur_gz" == "on" ]] && echo "off" || echo "on")
               _nginx_conf_set_param "gzip" "$n" "http"; ok "Set"; pause ;;
            2) blank; echo "  1) 1  2) 4  3) 6  4) 9"; blank; hr; blank
               local g; menu_pick g "1" "4" "6" "9" || continue
               local v=("1" "4" "6" "9")
               _nginx_conf_set_param "gzip_comp_level" "${v[$((g-1))]}" "http"; ok "Set"; pause ;;
            3) local v; ask v "gzip_min_length" "${cur_min:-1024}" && \
               { _nginx_conf_set_param "gzip_min_length" "$v" "http"; ok "Set"; pause; } ;;
            4) local n; n=$([[ "$cur_vary" == "on" ]] && echo "off" || echo "on")
               _nginx_conf_set_param "gzip_vary" "$n" "http"; ok "Set"; pause ;;
            5) blank; echo "  1) off  2) any  3) no-cache  4) expired"; blank; hr; blank
               local g; menu_pick g "off" "any" "no-cache" "expired" || continue
               local v=("off" "any" "no-cache" "expired")
               _nginx_conf_set_param "gzip_proxied" "${v[$((g-1))]}" "http"; ok "Set"; pause ;;
            6) _nginx_conf_backup "gzip_recommended" >/dev/null
               _nginx_conf_set_param "gzip" "on" "http" "gzip_recommended"
               _nginx_conf_set_param "gzip_comp_level" "6" "http" "gzip_recommended"
               _nginx_conf_set_param "gzip_min_length" "1024" "http" "gzip_recommended"
               _nginx_conf_set_param "gzip_vary" "on" "http" "gzip_recommended"
               _nginx_conf_set_param "gzip_proxied" "any" "http" "gzip_recommended"
               _nginx_conf_set_param "gzip_types" "text/plain text/css text/xml text/javascript application/json application/javascript image/svg+xml" "http" "gzip_recommended"
               ok "Recommended applied"; pause ;;
            0) return ;;
        esac
    done
}

_nginx_test_show() { section_banner "nginx -t" ""; nginx_test_quiet || true; pause; }

_nginx_apply() {
    section_banner "Apply nginx" ""
    info "Testing config…"; blank
    if nginx_test_quiet; then
        blank
        confirm "Reload nginx now?" && {
            nginx_reload && ok "nginx reloaded." || err_pause "Reload failed."
        }
    else
        err_pause "Configuration test failed — nginx NOT reloaded."
    fi
    pause
}

_nginx_conf_history() {
    while true; do
        section_banner "nginx.conf — Backup History" "${NGINX_CONF_BAK_DIR}"
        local baks=()
        [[ -d "$NGINX_CONF_BAK_DIR" ]] && \
            while IFS= read -r line; do baks+=("$line"); done < <(ls -t "${NGINX_CONF_BAK_DIR}"/ 2>/dev/null | head -20)

        if [[ ${#baks[@]} -eq 0 ]]; then info "No backups."; pause; return; fi

        local i=1
        for b in "${baks[@]}"; do printf "  ${BLUE}%3d)${R}  %s\n" "$i" "$b"; (( i++ )) || true; done
        blank; hr; blank
        local c; menu_choice c "Select" 0 "${#baks[@]}" || return
        (( c == 0 )) && return
        local chosen="${baks[$((c-1))]}"
        if confirm "Restore from '${chosen}'?"; then
            _nginx_conf_backup "pre_restore" >/dev/null
            cp "${NGINX_CONF_BAK_DIR}/${chosen}" "$NGINX_CONF"
            ok "Restored."
            _log "nginx.conf restored from ${chosen}"
            pause; return
        fi
    done
}

# ==============================================================================
#  SITES section
# ==============================================================================
section_sites() {
    while true; do
        section_banner "VIRTUAL HOSTS" "${NGINX_CONFD}/"
        echo -e "  ${DIM}Managed sites : ${WHITE}$(sites_count)${R}"
        blank
        echo -e "  ${BLUE}  1)${R}  List all virtual hosts"
        echo -e "  ${BLUE}  2)${R}  Create new virtual host"
        echo -e "  ${BLUE}  3)${R}  Edit existing virtual host"
        echo -e "  ${BLUE}  4)${R}  View virtual host config"
        echo -e "  ${BLUE}  5)${R}  Enable / disable virtual host"
        echo -e "  ${BLUE}  6)${R}  Delete virtual host"
        echo -e "  ${BLUE}  7)${R}  Check all site configs"
        echo -e "  ${RED}  0)${R}  Back to main menu"
        blank; hr; blank
        local c; menu_choice c "Select" 0 7 || return
        case "$c" in
            1) _sites_list_show ;;
            2) _site_create ;;
            3) _site_edit ;;
            4) _site_view ;;
            5) _site_toggle ;;
            6) _site_delete ;;
            7) _sites_check_all ;;
            0) return ;;
        esac
    done
}

_sites_list_show() {
    section_banner "Virtual Hosts — All Sites" ""
    local rows; rows=$(sites_list)
    if [[ -z "$rows" ]]; then
        info "No managed virtual hosts yet."
    else
        printf "  %-20s %-30s %-6s %-10s %-9s %s\n" "NAME" "SERVER_NAME" "PORT" "STATUS" "TYPE" "CONFIG"
        hr
        while IFS='|' read -r name conf sn port _ _ status _ stype _; do
            [[ -z "$name" ]] && continue
            local fstat="missing"
            [[ -f "$conf" ]] && fstat="ok"
            [[ -f "${conf}.disabled" ]] && fstat="disabled-file"
            local sstr
            case "$status" in
                enabled)  sstr="${GREEN}enabled ${R}" ;;
                disabled) sstr="${YELLOW}disabled${R}" ;;
                *)        sstr="${DIM}${status}${R}" ;;
            esac
            printf "  %-20s %-30s %-6s " "$name" "$sn" "$port"
            printf "%b   %-9s %s [%s]\n" "$sstr" "${stype:-?}" "$(basename "$conf")" "$fstat"
        done <<< "$rows"
    fi
    pause
}

_site_create() {
    section_banner "Create Virtual Host" "Config placed in ${NGINX_CONFD}/"

    local name sn listen_port
    ask name "Site name (identifier, no spaces)" || return
    name="${name//[^a-zA-Z0-9_-]/_}"

    if [[ -f "${NGINX_CONFD}/${name}.conf" ]]; then
        warn "Config ${NGINX_CONFD}/${name}.conf already exists."
        confirm "Overwrite?" || return
    fi

    blank
    echo -e "  ${BOLD}Site type:${R}"
    blank
    echo -e "  ${BLUE}  1)${R}  Reverse proxy"
    echo -e "  ${BLUE}  2)${R}  Static site"
    echo -e "  ${BLUE}  3)${R}  Reverse proxy + SSL  ${DIM}(auto-generates self-signed cert + HTTP→HTTPS redirect)${R}"
    echo -e "  ${BLUE}  4)${R}  HTTP redirect to HTTPS"
    blank; hr; blank

    local stype_idx; menu_pick stype_idx "rp" "static" "rp_ssl" "redir" || return
    local stypes=("rp" "static" "rp_ssl" "redir")
    local stype="${stypes[$((stype_idx-1))]}"

    blank
    ask sn "server_name (domain or IP)" || return

    local default_port="80"
    [[ "$stype" == "rp_ssl" ]] && default_port="443"
    ask listen_port "Listen port" "$default_port" || return

    local conf_file="${NGINX_CONFD}/${name}.conf"
    local cert_path="" key_path="" upstream_addr="" static_root=""

    case "$stype" in
        rp|rp_ssl)
            local up_ip up_port
            ask up_ip "Upstream IP address" || return
            ask up_port "Upstream port" "3000" || return
            upstream_addr="${up_ip}:${up_port}"

            if [[ "$stype" == "rp_ssl" ]]; then
                [[ "$listen_port" == "80" ]] && listen_port="443"

                blank
                echo -e "  ${BOLD}Certificate source:${R}"
                blank
                echo -e "  ${BLUE}  1)${R}  Auto-generate self-signed cert  ${DIM}(recommended for testing)${R}"
                echo -e "  ${BLUE}  2)${R}  Select existing cert from /etc/nginx/ssl/"
                echo -e "  ${BLUE}  3)${R}  Enter cert path manually"
                blank; hr; blank

                local cert_src; menu_pick cert_src "auto" "pick" "manual" || return
                local cert_srcs=("auto" "pick" "manual")
                local cs="${cert_srcs[$((cert_src-1))]}"

                case "$cs" in
                    auto)
                        GEN_CERT_PATH=""
                        GEN_KEY_PATH=""
                        if ! generate_self_signed_cert "$sn"; then
                            err_pause "Self-signed cert generation failed. Aborting site creation."
                            return
                        fi
                        cert_path="$GEN_CERT_PATH"
                        key_path="$GEN_KEY_PATH"
                        ;;
                    pick)
                        cert_path=$(_pick_cert_path "Select certificate") || return
                        [[ -z "$cert_path" ]] && { warn "No cert selected"; pause; return; }
                        key_path=$(_pick_key_path "Select private key") || return
                        [[ -z "$key_path" ]] && { warn "No key selected"; pause; return; }
                        ;;
                    manual)
                        ask cert_path "Full path to certificate" || return
                        ask key_path "Full path to private key" || return
                        ;;
                esac
            fi

            _write_rp_conf "$conf_file" "$sn" "$listen_port" "$upstream_addr" \
                           "$([[ "$stype" == "rp_ssl" ]] && echo "yes" || echo "no")" \
                           "$cert_path" "$key_path" "$name"
            ;;
        static)
            ask static_root "Document root path" "/var/www/${name}" || return
            mkdir -p "$static_root"
            _write_static_conf "$conf_file" "$sn" "$listen_port" "$static_root"
            ;;
        redir)
            local redir_to
            ask redir_to "Redirect target URL" "https://${sn}" || return
            _write_redir_conf "$conf_file" "$sn" "$listen_port" "$redir_to"
            ;;
    esac

    site_add "$name" "$conf_file" "$sn" "$listen_port" "$cert_path" "$key_path" "enabled" \
             "$stype" "$upstream_addr"

    blank; hr; blank
    ok "Virtual host '${name}' created: ${conf_file}"
    blank
    info "Testing nginx configuration…"; blank
    if nginx_test_quiet; then
        blank
        confirm "Reload nginx now?" && {
            nginx_reload && ok "nginx reloaded." || err_pause "Reload failed."
        }
    else
        err_pause "nginx -t failed — review ${conf_file}"
    fi
    pause
}

# ------------------------------------------------------------------------------
# Config writers — with automatic HTTP→HTTPS redirect for SSL sites
# ------------------------------------------------------------------------------
_write_rp_conf() {
    local conf="$1" sn="$2" port="$3" upstream="$4" ssl="$5" cert="$6" key="$7" uname="${8:-backend}"
    local up_name="${uname}_upstream"
    local ssl_suffix=""
    [[ "$ssl" == "yes" ]] && ssl_suffix=" ssl"

    : > "$conf"

    # AUTOMATIC HTTP -> HTTPS REDIRECT BLOCK for SSL sites
    if [[ "$ssl" == "yes" ]]; then
        cat >> "$conf" <<EOF
# pngxconf — reverse proxy + SSL — ${sn}
# Generated: $(date '+%Y-%m-%d %H:%M:%S')

# Automatic HTTP -> HTTPS redirect
server {
    listen      80;
    listen      [::]:80;
    server_name ${sn};

    # ACME HTTP-01 challenge passthrough (for Let's Encrypt)
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://\$host\$request_uri;
    }
}

EOF
    else
        cat >> "$conf" <<EOF
# pngxconf — reverse proxy — ${sn}
# Generated: $(date '+%Y-%m-%d %H:%M:%S')

EOF
    fi

    cat >> "$conf" <<EOF
upstream ${up_name} {
    server ${upstream};
    keepalive 32;
}

server {
    listen      ${port}${ssl_suffix};
    listen      [::]:${port}${ssl_suffix};
    server_name ${sn};

    server_tokens off;

EOF

    if [[ "$ssl" == "yes" ]]; then
        cat >> "$conf" <<EOF
    # ── SSL ──────────────────────────────────────────────────────────
    ssl_certificate         ${cert};
    ssl_certificate_key     ${key};
    ssl_protocols           TLSv1.2 TLSv1.3;
    ssl_ciphers             ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache       shared:SSL:10m;
    ssl_session_timeout     1d;
    ssl_session_tickets     off;

EOF
    fi

    cat >> "$conf" <<EOF
    # ── Security headers ─────────────────────────────────────────────
    add_header X-Frame-Options         "SAMEORIGIN"                        always;
    add_header X-Content-Type-Options  "nosniff"                           always;
    add_header X-XSS-Protection        "1; mode=block"                     always;
    add_header Referrer-Policy         "strict-origin-when-cross-origin"   always;

    # ── Logging ──────────────────────────────────────────────────────
    access_log  /var/log/nginx/${sn}_access.log;
    error_log   /var/log/nginx/${sn}_error.log warn;

    # ── Proxy ────────────────────────────────────────────────────────
    location / {
        proxy_pass              http://${up_name};
        proxy_http_version      1.1;
        proxy_set_header        Host              \$host;
        proxy_set_header        X-Real-IP         \$remote_addr;
        proxy_set_header        X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header        X-Forwarded-Proto \$scheme;
        proxy_set_header        Connection        "";
        proxy_read_timeout      60s;
        proxy_connect_timeout   10s;
        proxy_send_timeout      60s;
        proxy_buffering         on;
        proxy_buffer_size       4k;
        proxy_buffers           8 4k;
    }
}
EOF
}

_write_static_conf() {
    local conf="$1" sn="$2" port="$3" root="$4"
    cat > "$conf" <<EOF
# pngxconf — static site — ${sn}
# Generated: $(date '+%Y-%m-%d %H:%M:%S')

server {
    listen      ${port};
    listen      [::]:${port};
    server_name ${sn};

    server_tokens off;

    root  ${root};
    index index.html index.htm;

    add_header X-Frame-Options        "SAMEORIGIN"  always;
    add_header X-Content-Type-Options "nosniff"     always;

    access_log  /var/log/nginx/${sn}_access.log;
    error_log   /var/log/nginx/${sn}_error.log warn;

    location / {
        try_files \$uri \$uri/ =404;
    }
}
EOF
}

_write_redir_conf() {
    local conf="$1" sn="$2" port="$3" target="$4"
    cat > "$conf" <<EOF
# pngxconf — redirect — ${sn}
# Generated: $(date '+%Y-%m-%d %H:%M:%S')

server {
    listen      ${port};
    listen      [::]:${port};
    server_name ${sn};
    server_tokens off;

    access_log  /var/log/nginx/${sn}_access.log;
    return 301  ${target}\$request_uri;
}
EOF
}

