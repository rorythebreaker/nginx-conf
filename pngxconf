_certs_check_expiry() {
    section_banner "Certificate Expiry Check" ""
    local rows; rows=$(certs_list)
    if [[ -z "$rows" ]]; then
        info "No registered certificates."
        read -rp "  Press Enter…" _; return
    fi

    local today; today=$(date +%s)
    while IFS='|' read -r name domain cert _ _ _ _; do
        printf "  %-22s %-32s " "$name" "$domain"
        if [[ ! -f "$cert" ]]; then
            printf "${RED}cert file missing${R}\n"; continue
        fi
        local enddate; enddate=$(openssl x509 -noout -enddate -in "$cert" 2>/dev/null | cut -d= -f2 || echo "")
        if [[ -z "$enddate" ]]; then
            printf "${YELLOW}cannot read${R}\n"; continue
        fi
        local exp_epoch; exp_epoch=$(date -d "$enddate" +%s 2>/dev/null || date -j -f "%b %d %T %Y %Z" "$enddate" +%s 2>/dev/null || echo 0)
        local days_left=$(( (exp_epoch - today) / 86400 ))
        if (( days_left < 0 )); then
            printf "${RED}EXPIRED %d days ago${R}\n" "$(( -days_left ))"
        elif (( days_left < 30 )); then
            printf "${YELLOW}expires in %d days${R}  [%s]\n" "$days_left" "$enddate"
        else
            printf "${GREEN}valid %d days${R}  [%s]\n" "$days_left" "$enddate"
        fi
    done <<< "$rows"
    blank; read -rp "  Press Enter…" _
}

_cert_remove() {
    section_banner "Remove Certificate Record" ""
    local rows; rows=$(certs_list)
    [[ -z "$rows" ]] && { info "No registered certificates."; read -rp "  Press Enter…" _; return; }

    local i=1; declare -a names=()
    while IFS='|' read -r name domain _ _ _ _ _; do
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${domain})${R}"
        names+=("$name"); (( i++ ))
    done <<< "$rows"
    blank; hr; blank

    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"

    blank
    warn "Remove from database only (files on disk will NOT be deleted)."
    confirm "Remove record '${chosen}'?" || { info "Cancelled."; read -rp "  Press Enter…" _; return; }
    cert_remove "$chosen"
    ok "Record '${chosen}' removed."
    _log "cert record removed: ${chosen}"
    blank; read -rp "  Press Enter…" _
}

