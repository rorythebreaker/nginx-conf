_cert_create_wizard() {
    local wizard; wizard=$(state_get "SSL_WIZARD_PATH")
    if [[ -z "$wizard" || ! -f "$wizard" ]]; then
        # Search again
        for p in \
            "$(dirname "$(readlink -f "$0")")/ssl-wizard.sh" \
            "/usr/local/lib/pngxconf/ssl-wizard.sh" \
            "${PNGX_STATE_DIR}/ssl-wizard.sh"
        do
            [[ -f "$p" ]] && { wizard="$p"; state_set "SSL_WIZARD_PATH" "$p"; break; }
        done
    fi

    if [[ -z "$wizard" || ! -f "$wizard" ]]; then
        section_banner "SSL Wizard — Not Found" ""
        err "ssl-wizard.sh not found."
        blank
        warn "Place ssl-wizard.sh in one of:"
        echo -e "  ${DIM}/usr/local/lib/pngxconf/ssl-wizard.sh${R}"
        echo -e "  ${DIM}${PNGX_STATE_DIR}/ssl-wizard.sh${R}"
        echo -e "  ${DIM}same directory as pngxconf${R}"
        blank
        # Offer manual path
        if confirm "Enter path to ssl-wizard.sh manually?"; then
            local wp; ask wp "Full path to ssl-wizard.sh" || { read -rp "  Press Enter…" _; return; }
            if [[ -f "$wp" ]]; then
                state_set "SSL_WIZARD_PATH" "$wp"
                wizard="$wp"
            else
                err "File not found: ${wp}"; read -rp "  Press Enter…" _; return
            fi
        else
            read -rp "  Press Enter…" _; return
        fi
    fi

    # Run ssl-wizard.sh — it outputs to its own chosen S_OUTDIR
    # After it exits, scan NGINX_SSL_DIR for new files and register them
    local ssl_files_before
    ssl_files_before=$(find "$NGINX_SSL_DIR" -type f \( -name "*.crt" -o -name "*.pem" -o -name "*.key" \) 2>/dev/null | sort || true)

    bash "$wizard"

    local ssl_files_after
    ssl_files_after=$(find "$NGINX_SSL_DIR" -type f \( -name "*.crt" -o -name "*.pem" -o -name "*.key" \) 2>/dev/null | sort || true)

    local new_files
    new_files=$(comm -13 <(echo "$ssl_files_before") <(echo "$ssl_files_after") || true)

    if [[ -n "$new_files" ]]; then
        blank; hr
        ok "New certificate files detected in ${NGINX_SSL_DIR}:"
        echo "$new_files"
        blank
        if confirm "Register these certificates in pngxconf?"; then
            _cert_register_from_dir "$NGINX_SSL_DIR"
        fi
    fi
}

_cert_register_from_dir() {
    local dir="$1"
    section_banner "Register Certificates from Directory" "$dir"
    local name domain cert key chain

    # find .crt or fullchain.pem
    while IFS= read -r -d '' cfile; do
        [[ "$cfile" == *.key ]] && continue
        local base; base=$(basename "$cfile" | sed 's/_fullchain\.pem$//' | sed 's/\.crt$//' | sed 's/\.pem$//')
        info "Found: ${cfile}"
        ask name "Record name for this cert" "$base" || continue
        ask domain "Domain this cert covers" "$base" || continue

        cert="$cfile"
        # find matching key
        key=""
        for kext in ".key" "_privkey.pem"; do
            local try="${dir}/${base}${kext}"
            [[ -f "$try" ]] && { key="$try"; break; }
        done
        if [[ -z "$key" ]]; then
            ask_optional key "Path to private key (Enter to skip)" || true
        fi

        chain=""
        local try_chain="${dir}/${base}_chain.pem"
        [[ -f "$try_chain" ]] && chain="$try_chain"

        cert_add "$name" "$domain" "$cert" "$key" "$chain" "ssl-wizard"
        ok "Registered: ${name}"
    done < <(find "$dir" -maxdepth 2 -type f \( -name "*.crt" -o -name "*fullchain*" \) -print0 2>/dev/null || true)
    blank; read -rp "  Press Enter…" _
}

_cert_upload() {
    section_banner "Upload / Register Certificate" "Copies files to ${NGINX_SSL_DIR}/<domain>/"
    local name domain cert_src key_src chain_src

    ask name "Record name (identifier)" || return
    ask domain "Domain this certificate covers" || return

    local dest_dir="${NGINX_SSL_DIR}/${domain}"
    mkdir -p "$dest_dir"
    chmod 700 "$dest_dir"

    # cert
    blank; ask cert_src "Full path to certificate file (.crt or .pem)" || return
    if [[ ! -f "$cert_src" ]]; then err "File not found: ${cert_src}"; read -rp "  Press Enter…" _; return; fi
    local cert_dest="${dest_dir}/${domain}.crt"
    cp "$cert_src" "$cert_dest"
    chmod 644 "$cert_dest"
    ok "Certificate copied to: ${cert_dest}"

    # key
    blank; ask key_src "Full path to private key file (.key or .pem)" || return
    if [[ ! -f "$key_src" ]]; then err "File not found: ${key_src}"; read -rp "  Press Enter…" _; return; fi
    local key_dest="${dest_dir}/${domain}.key"
    cp "$key_src" "$key_dest"
    chmod 600 "$key_dest"
    ok "Private key copied to: ${key_dest}"

    # chain (optional)
    local chain_dest=""
    blank
    ask_optional chain_src "Path to chain/intermediate file (Enter to skip)" || true
    if [[ -n "$chain_src" && -f "$chain_src" ]]; then
        chain_dest="${dest_dir}/${domain}.chain.pem"
        cp "$chain_src" "$chain_dest"
        chmod 644 "$chain_dest"
        ok "Chain copied to: ${chain_dest}"
    fi

    cert_add "$name" "$domain" "$cert_dest" "$key_dest" "$chain_dest" "manual"
    ok "Certificate '${name}' registered."
    info "cert : ${cert_dest}"
    info "key  : ${key_dest}"
    [[ -n "$chain_dest" ]] && info "chain: ${chain_dest}"
    _log "cert uploaded: name=${name} domain=${domain} cert=${cert_dest}"
    blank; read -rp "  Press Enter…" _
}

_cert_inspect() {
    section_banner "Inspect Certificate" ""
    local rows; rows=$(certs_list)
    if [[ -z "$rows" ]]; then
        info "No registered certificates."
        read -rp "  Press Enter…" _; return
    fi

    local i=1; declare -a names=()
    while IFS='|' read -r name domain _ _ _ _ _; do
