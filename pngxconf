_nginx_conf_history() {
    section_banner "nginx.conf — Backup History" "${NGINX_CONF_BAK_DIR}"
    local baks; baks=$(ls -lt "${NGINX_CONF_BAK_DIR}"/ 2>/dev/null | grep '^-' | head -20 || true)
    if [[ -z "$baks" ]]; then
        info "No backups found."
    else
        echo "$baks"
        blank
        if confirm "Restore a backup?"; then
            blank
            local i=1
            declare -a bfiles=()
            while IFS= read -r line; do
                local fname; fname=$(echo "$line" | awk '{print $NF}')
                echo -e "  ${BLUE}  ${i})${R}  ${fname}"
                bfiles+=("$fname")
                (( i++ ))
            done < <(ls -t "${NGINX_CONF_BAK_DIR}"/ 2>/dev/null | head -10)
            blank; hr; blank
            local bc; printf "  Select [1-%d]  (b = back): " "${#bfiles[@]}"; IFS= read -r bc
            if [[ "$bc" =~ ^[0-9]+$ ]] && (( bc >= 1 && bc <= ${#bfiles[@]} )); then
                local chosen="${bfiles[$((bc-1))]}"
                _nginx_conf_backup "pre_restore" >/dev/null
                cp "${NGINX_CONF_BAK_DIR}/${chosen}" "$NGINX_CONF"
                ok "Restored from: ${chosen}"
                _log "nginx.conf restored from ${chosen}"
            fi
        fi
    fi
    blank; read -rp "  Press Enter…" _
}

