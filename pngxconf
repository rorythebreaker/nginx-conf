_site_edit() {
    section_banner "Edit Virtual Host" ""
    local rows; rows=$(sites_list)
    [[ -z "$rows" ]] && { info "No sites."; pause; return; }

    # List only rp / rp_ssl sites (others not yet editable here)
    local i=1; declare -a names=() types=()
    while IFS='|' read -r name conf sn port _ _ status _ stype _; do
        [[ -z "$name" ]] && continue
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${sn}:${port} — ${stype:-?})${R}"
        names+=("$name"); types+=("$stype")
        (( i++ )) || true
    done <<< "$rows"
    blank; hr; blank

    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"
    local chosen_type="${types[$((c-1))]}"

    if [[ "$chosen_type" != "rp" && "$chosen_type" != "rp_ssl" ]]; then
        warn "Edit menu currently supports reverse proxy and reverse proxy + SSL sites only."
        info "For other types, view config and edit ${NGINX_CONFD}/${chosen}.conf manually."
        pause
        return
    fi

    _site_edit_rp "$chosen"
}

_site_edit_rp() {
    local name="$1"

    while true; do
        # Load current values from DB
        local cur_conf cur_sn cur_port cur_cert cur_key cur_status cur_stype cur_up
        cur_conf=$(site_get_field "$name" 2)
        cur_sn=$(site_get_field "$name" 3)
        cur_port=$(site_get_field "$name" 4)
        cur_cert=$(site_get_field "$name" 5)
        cur_key=$(site_get_field "$name" 6)
        cur_status=$(site_get_field "$name" 7)
        cur_stype=$(site_get_field "$name" 9)
        cur_up=$(site_get_field "$name" 10)

        section_banner "Edit '${name}'" "${cur_conf}"

        echo -e "  ${DIM}server_name :${R} ${WHITE}${cur_sn}${R}"
        echo -e "  ${DIM}listen port :${R} ${WHITE}${cur_port}${R}"
        echo -e "  ${DIM}upstream    :${R} ${WHITE}${cur_up}${R}"
        echo -e "  ${DIM}type        :${R} ${WHITE}${cur_stype}${R}"
        if [[ "$cur_stype" == "rp_ssl" ]]; then
            echo -e "  ${DIM}ssl cert    :${R} ${WHITE}${cur_cert}${R}"
            echo -e "  ${DIM}ssl key     :${R} ${WHITE}${cur_key}${R}"
        fi
        echo -e "  ${DIM}status      :${R} ${WHITE}${cur_status}${R}"
        blank

        echo -e "  ${BLUE}  1)${R}  Change server_name"
        echo -e "  ${BLUE}  2)${R}  Change listen port"
        echo -e "  ${BLUE}  3)${R}  Change upstream IP:port"
        if [[ "$cur_stype" == "rp" ]]; then
            echo -e "  ${BLUE}  4)${R}  Convert to ${GREEN}SSL${R}  ${DIM}(auto cert + HTTP→HTTPS redirect)${R}"
        else
            echo -e "  ${BLUE}  4)${R}  Replace SSL certificate"
            echo -e "  ${BLUE}  5)${R}  Convert back to plain HTTP"
        fi
        echo -e "  ${BLUE}  6)${R}  Regenerate config file from current settings"
        echo -e "  ${BLUE}  7)${R}  View current config"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank

        local c; menu_choice c "Select" 0 7 || return
        case "$c" in
            1)
                local new_sn
                ask new_sn "New server_name" "$cur_sn" || continue
                site_update_field "$name" 3 "$new_sn"
                _rewrite_site_config "$name"
                ok "server_name updated to '${new_sn}' — config rewritten"
                _site_test_and_reload
                ;;
            2)
                local new_port
                ask new_port "New listen port" "$cur_port" || continue
                site_update_field "$name" 4 "$new_port"
                _rewrite_site_config "$name"
                ok "Listen port updated to '${new_port}'"
                _site_test_and_reload
                ;;
            3)
                local new_ip new_p
                local cur_ip="${cur_up%%:*}" cur_p="${cur_up##*:}"
                ask new_ip "New upstream IP" "$cur_ip" || continue
                ask new_p "New upstream port" "$cur_p" || continue
                local new_up="${new_ip}:${new_p}"
                site_update_field "$name" 10 "$new_up"
                _rewrite_site_config "$name"
                ok "Upstream updated to '${new_up}'"
                _site_test_and_reload
                ;;
            4)
                if [[ "$cur_stype" == "rp" ]]; then
                    # Convert rp -> rp_ssl
                    blank
                    echo -e "  ${BOLD}Choose SSL source:${R}"
                    blank
                    echo -e "  ${BLUE}  1)${R}  Auto-generate self-signed cert"
                    echo -e "  ${BLUE}  2)${R}  Pick existing cert"
                    echo -e "  ${BLUE}  3)${R}  Enter cert path manually"
                    blank; hr; blank
                    local cs; menu_pick cs "auto" "pick" "manual" || continue
                    local css=("auto" "pick" "manual")
                    local cert_p="" key_p=""
                    case "${css[$((cs-1))]}" in
                        auto)
                            GEN_CERT_PATH=""; GEN_KEY_PATH=""
                            if ! generate_self_signed_cert "$cur_sn"; then
                                err_pause "Cert generation failed"; continue
                            fi
                            cert_p="$GEN_CERT_PATH"; key_p="$GEN_KEY_PATH" ;;
                        pick)
                            cert_p=$(_pick_cert_path "Select certificate") || continue
                            [[ -z "$cert_p" ]] && continue
                            key_p=$(_pick_key_path "Select private key") || continue
                            [[ -z "$key_p" ]] && continue ;;
                        manual)
                            ask cert_p "Cert path" || continue
                            ask key_p "Key path" || continue ;;
                    esac

                    site_update_field "$name" 5 "$cert_p"
                    site_update_field "$name" 6 "$key_p"
                    site_update_field "$name" 4 "443"
                    site_update_field "$name" 9 "rp_ssl"
                    _rewrite_site_config "$name"
                    ok "Converted to SSL — HTTP→HTTPS redirect added automatically"
                    _site_test_and_reload
                else
                    # rp_ssl — replace cert
                    blank
                    echo -e "  ${BOLD}Choose new cert:${R}"
                    blank
                    echo -e "  ${BLUE}  1)${R}  Auto-generate new self-signed cert"
                    echo -e "  ${BLUE}  2)${R}  Pick from /etc/nginx/ssl/"
                    echo -e "  ${BLUE}  3)${R}  Manual path"
                    blank; hr; blank
                    local cs; menu_pick cs "auto" "pick" "manual" || continue
                    local css=("auto" "pick" "manual")
                    local cert_p="" key_p=""
                    case "${css[$((cs-1))]}" in
                        auto)
                            GEN_CERT_PATH=""; GEN_KEY_PATH=""
                            if ! generate_self_signed_cert "$cur_sn"; then
                                err_pause "Cert generation failed"; continue
                            fi
                            cert_p="$GEN_CERT_PATH"; key_p="$GEN_KEY_PATH" ;;
                        pick)
                            cert_p=$(_pick_cert_path "Select certificate") || continue
                            key_p=$(_pick_key_path "Select private key") || continue ;;
                        manual)
                            ask cert_p "Cert path" "$cur_cert" || continue
                            ask key_p "Key path" "$cur_key" || continue ;;
                    esac
                    site_update_field "$name" 5 "$cert_p"
                    site_update_field "$name" 6 "$key_p"
                    _rewrite_site_config "$name"
                    ok "Certificate replaced"
                    _site_test_and_reload
                fi
                ;;
            5)
                if [[ "$cur_stype" == "rp_ssl" ]]; then
                    if confirm "Convert SSL site to plain HTTP? (HTTPS redirect and SSL block will be removed)"; then
                        site_update_field "$name" 5 ""
                        site_update_field "$name" 6 ""
                        site_update_field "$name" 4 "80"
                        site_update_field "$name" 9 "rp"
                        _rewrite_site_config "$name"
                        ok "Converted to plain HTTP"
                        _site_test_and_reload
                    fi
                fi
                ;;
            6)
                _rewrite_site_config "$name"
                ok "Config file rewritten from DB values"
                _site_test_and_reload
                ;;
            7)
                blank
                local cf; cf=$(site_get_field "$name" 2)
                if [[ -f "$cf" ]]; then
                    cat -n "$cf"
                elif [[ -f "${cf}.disabled" ]]; then
                    info "Site is disabled:"
                    cat -n "${cf}.disabled"
                else
                    err_pause "Config file not found"
                fi
                pause
                ;;
            0) return ;;
        esac
    done
}

_rewrite_site_config() {
    local name="$1"
    local conf sn port cert key stype upstream
    conf=$(site_get_field "$name" 2)
    sn=$(site_get_field "$name" 3)
    port=$(site_get_field "$name" 4)
    cert=$(site_get_field "$name" 5)
    key=$(site_get_field "$name" 6)
    stype=$(site_get_field "$name" 9)
    upstream=$(site_get_field "$name" 10)

    # Backup current
    if [[ -f "$conf" ]]; then
        local bak="${conf}.bak.$(date +%Y%m%d_%H%M%S)"
        cp "$conf" "$bak"
        _log "site '${name}' config backup: ${bak}"
    fi

    case "$stype" in
        rp)     _write_rp_conf "$conf" "$sn" "$port" "$upstream" "no"  ""    ""   "$name" ;;
        rp_ssl) _write_rp_conf "$conf" "$sn" "$port" "$upstream" "yes" "$cert" "$key" "$name" ;;
        static) _write_static_conf "$conf" "$sn" "$port" "/var/www/${name}" ;;
        redir)  _write_redir_conf "$conf" "$sn" "$port" "https://${sn}" ;;
    esac
    _log "site '${name}' config rewritten"
}

_site_test_and_reload() {
    blank
    info "Testing nginx config…"; blank
    if nginx_test_quiet; then
        blank
        confirm "Reload nginx?" && {
            nginx_reload && ok "nginx reloaded." || err_pause "Reload failed."
        }
    else
        err_pause "nginx -t failed — config NOT applied. Edit the file manually or restore backup."
    fi
    pause
}

# ------------------------------------------------------------------------------
# Cert/key pickers
# ------------------------------------------------------------------------------
_pick_cert_path() {
    local hint="${1:-Select certificate}"
    exec 3>&1
    {
        blank
        echo -e "  ${BOLD}${hint}${R}"
        blank
    } >&2
    local certs=()
    if [[ -d "$NGINX_SSL_DIR" ]]; then
        while IFS= read -r -d '' f; do certs+=("$f"); done < \
            <(find "$NGINX_SSL_DIR" -maxdepth 3 -type f \( -name "*.crt" -o -name "*.pem" -o -name "*.cer" \) -print0 2>/dev/null)
    fi
    local i=1
    for f in "${certs[@]}"; do echo -e "  ${BLUE}  ${i})${R}  ${f}" >&2; (( i++ )) || true; done
    local total=${#certs[@]}
    echo -e "  ${BLUE}  $((total+1)))${R}  Enter path manually" >&2
    echo "" >&2; hr >&2; echo "" >&2
    local c
    printf "  Select [1-%d]  ${DIM}(b = back)${R}: " "$((total+1))" >&2
    IFS= read -r c
    if [[ "${c,,}" == "b" ]]; then exec 3>&-; return 1; fi
    if [[ "$c" =~ ^[0-9]+$ ]] && (( c >= 1 && c <= total )); then
        printf '%s\n' "${certs[$((c-1))]}" >&3; exec 3>&-; return 0
    elif [[ "$c" =~ ^[0-9]+$ ]] && (( c == total+1 )); then
        local mp; ask mp "Full path to certificate" || { exec 3>&-; return 1; }
        printf '%s\n' "$mp" >&3; exec 3>&-; return 0
    fi
    exec 3>&-; return 1
}

_pick_key_path() {
    local hint="${1:-Select private key}"
    exec 3>&1
    {
        blank
        echo -e "  ${BOLD}${hint}${R}"
        blank
    } >&2
    local keys=()
    if [[ -d "$NGINX_SSL_DIR" ]]; then
        while IFS= read -r -d '' f; do keys+=("$f"); done < \
            <(find "$NGINX_SSL_DIR" -maxdepth 3 -type f -name "*.key" -print0 2>/dev/null)
    fi
    local i=1
    for f in "${keys[@]}"; do echo -e "  ${BLUE}  ${i})${R}  ${f}" >&2; (( i++ )) || true; done
    local total=${#keys[@]}
    echo -e "  ${BLUE}  $((total+1)))${R}  Enter path manually" >&2
    echo "" >&2; hr >&2; echo "" >&2
    local c
    printf "  Select [1-%d]  ${DIM}(b = back)${R}: " "$((total+1))" >&2
    IFS= read -r c
    if [[ "${c,,}" == "b" ]]; then exec 3>&-; return 1; fi
    if [[ "$c" =~ ^[0-9]+$ ]] && (( c >= 1 && c <= total )); then
        printf '%s\n' "${keys[$((c-1))]}" >&3; exec 3>&-; return 0
    elif [[ "$c" =~ ^[0-9]+$ ]] && (( c == total+1 )); then
        local mp; ask mp "Full path to private key" || { exec 3>&-; return 1; }
        printf '%s\n' "$mp" >&3; exec 3>&-; return 0
    fi
    exec 3>&-; return 1
}

_site_view() {
    section_banner "View Virtual Host Config" ""
    local rows; rows=$(sites_list)
    [[ -z "$rows" ]] && { info "No sites."; pause; return; }
    local i=1; declare -a names=()
    while IFS='|' read -r name _ sn port _ _ status _ _ _; do
        [[ -z "$name" ]] && continue
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${sn}:${port} — ${status})${R}"
        names+=("$name"); (( i++ )) || true
    done <<< "$rows"
    blank; hr; blank
    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"
    local cf; cf=$(site_get_field "$chosen" 2)
    blank
    if [[ -f "$cf" ]]; then cat -n "$cf"
    elif [[ -f "${cf}.disabled" ]]; then info "Site is disabled:"; cat -n "${cf}.disabled"
    else err_pause "Config file not found: ${cf}"; return
    fi
    pause
}

_site_toggle() {
    section_banner "Enable / Disable" ""
    local rows; rows=$(sites_list)
    [[ -z "$rows" ]] && { info "No sites."; pause; return; }
    local i=1; declare -a names=()
    while IFS='|' read -r name _ sn _ _ _ status _ _ _; do
        [[ -z "$name" ]] && continue
        local b; [[ "$status" == "enabled" ]] && b="${GREEN}enabled${R}" || b="${YELLOW}disabled${R}"
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${sn})${R}  — ${b}"
        names+=("$name"); (( i++ )) || true
    done <<< "$rows"
    blank; hr; blank
    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"
    local cf; cf=$(site_get_field "$chosen" 2)
    local cs; cs=$(site_get_field "$chosen" 7)
    if [[ "$cs" == "enabled" ]]; then
        [[ -f "$cf" ]] && { mv "$cf" "${cf}.disabled"; ok "Disabled"; }
        site_set_status "$chosen" "disabled"
    else
        if [[ -f "${cf}.disabled" ]]; then
            mv "${cf}.disabled" "$cf"; ok "Enabled"
        elif [[ ! -f "$cf" ]]; then
            err_pause "Config file not found"; return
        fi
        site_set_status "$chosen" "enabled"
    fi
    blank
    confirm "Reload nginx?" && { nginx_reload && ok "Reloaded" || err_pause "Reload failed"; }
    pause
}

_site_delete() {
    section_banner "Delete Virtual Host" ""
    local rows; rows=$(sites_list)
    [[ -z "$rows" ]] && { info "No sites."; pause; return; }
    local i=1; declare -a names=()
    while IFS='|' read -r name _ sn _ _ _ _ _ _ _; do
        [[ -z "$name" ]] && continue
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${sn})${R}"
        names+=("$name"); (( i++ )) || true
    done <<< "$rows"
    blank; hr; blank
    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"
    local cf; cf=$(site_get_field "$chosen" 2)
    blank
    confirm "Delete '${chosen}'?" || { info "Cancelled."; pause; return; }
    [[ -f "$cf" ]] && { rm -f "$cf"; ok "Removed ${cf}"; }
    [[ -f "${cf}.disabled" ]] && { rm -f "${cf}.disabled"; ok "Removed ${cf}.disabled"; }
    site_remove "$chosen"
    ok "Removed from DB."
    blank
    confirm "Reload nginx?" && { nginx_reload && ok "Reloaded" || err_pause "Reload failed"; }
    pause
}

_sites_check_all() {
    section_banner "Sites — Integrity Check" ""
    local rows; rows=$(sites_list)
    if [[ -z "$rows" ]]; then
        info "No managed sites."
    else
        while IFS='|' read -r name conf _ _ cert key _ _ _ _; do
            [[ -z "$name" ]] && continue
            printf "  %-22s " "${name}:"
            if [[ -f "$conf" ]]; then printf "${GREEN}conf${R} "
            elif [[ -f "${conf}.disabled" ]]; then printf "${YELLOW}disabled${R} "
            else printf "${RED}conf-missing${R} "; fi
            if [[ -n "$cert" ]]; then
                [[ -f "$cert" ]] && printf "${GREEN}cert${R} " || printf "${RED}cert-missing${R} "
            fi
            if [[ -n "$key" ]]; then
                [[ -f "$key" ]] && printf "${GREEN}key${R} " || printf "${RED}key-missing${R} "
            fi
            echo ""
        done <<< "$rows"
    fi
    blank; hr; blank
    info "Running nginx -t:"; blank
    nginx_test_quiet || true
    pause
}

# ==============================================================================
#  CERTIFICATES section
# ==============================================================================
section_certs() {
    while true; do
        section_banner "SSL CERTIFICATES" "${NGINX_SSL_DIR}/"
        echo -e "  ${DIM}Known certificates : ${WHITE}$(certs_count)${R}"
        blank
        echo -e "  ${BLUE}  1)${R}  List all certificates"
        echo -e "  ${BLUE}  2)${R}  Create certificate via ssl-wizard.sh"
        echo -e "  ${BLUE}  3)${R}  Generate self-signed cert"
        echo -e "  ${BLUE}  4)${R}  Upload / register existing certificate"
        echo -e "  ${BLUE}  5)${R}  Inspect certificate"
        echo -e "  ${BLUE}  6)${R}  Check expiry for all registered certs"
        echo -e "  ${BLUE}  7)${R}  Remove certificate record"
        echo -e "  ${BLUE}  8)${R}  Firewall check (port 80 for ACME)"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank
        local c; menu_choice c "Select" 0 8 || return
        case "$c" in
            1) _certs_list_show ;;
            2) _cert_create_wizard ;;
            3) _cert_create_selfsigned ;;
            4) _cert_upload ;;
            5) _cert_inspect ;;
            6) _certs_check_expiry ;;
            7) _cert_remove ;;
            8) firewall_check_section ;;
            0) return ;;
        esac
    done
}

_certs_list_show() {
    section_banner "Certificates — All Records" ""
    local rows; rows=$(certs_list)
    if [[ -z "$rows" ]]; then
        info "No registered certificates."
    else
        printf "  %-22s %-30s %-14s %s\n" "NAME" "DOMAIN" "TYPE" "EXPIRY"
        hr
        while IFS='|' read -r name domain cert _ _ type _; do
            [[ -z "$name" ]] && continue
            local exp
            if [[ -f "$cert" ]]; then
                exp=$(openssl x509 -noout -enddate -in "$cert" 2>/dev/null | cut -d= -f2)
                [[ -z "$exp" ]] && exp="(unreadable)"
            else
                exp="(cert missing)"
            fi
            printf "  %-22s %-30s %-14s %s\n" "$name" "$domain" "$type" "$exp"
        done <<< "$rows"
    fi
    pause
}

_cert_create_selfsigned() {
    section_banner "Generate Self-Signed Certificate" ""
    local domain
    ask domain "Domain (e.g. example.com)" || return
    GEN_CERT_PATH=""; GEN_KEY_PATH=""
    if generate_self_signed_cert "$domain"; then
        blank; ok "Done."
    fi
    pause
}

_cert_create_wizard() {
    # Firewall check first
    if ! check_firewall_port80; then
        section_banner "Firewall Warning" ""
        warn "Port 80 appears to be blocked by your firewall."
        warn "Let's Encrypt HTTP-01 challenge requires port 80 reachable from internet."
        echo ""
        echo -e "  ${DIM}Run firewall check first (menu item 8) to inspect and fix.${R}"
        echo ""
        confirm "Proceed anyway?" || { pause; return; }
    fi

    local wizard; wizard=$(state_get "SSL_WIZARD_PATH")
    if [[ -z "$wizard" || ! -f "$wizard" ]]; then
        for p in "$PNGX_SSL_WIZARD_DEFAULT" \
                 "$(dirname "$(readlink -f "$0")")/ssl-wizard.sh" \
                 "${PNGX_STATE_DIR}/ssl-wizard.sh"; do
            [[ -f "$p" ]] && { wizard="$p"; state_set "SSL_WIZARD_PATH" "$p"; break; }
        done
    fi

    if [[ -z "$wizard" || ! -f "$wizard" ]]; then
        section_banner "SSL Wizard Not Found" ""
        err_pause "ssl-wizard.sh not found. Expected at: ${PNGX_SSL_WIZARD_DEFAULT}"
        return
    fi

    local before_files
    before_files=$(find "$NGINX_SSL_DIR" -type f \( -name "*.crt" -o -name "*.pem" -o -name "*.key" \) 2>/dev/null | sort)

    bash "$wizard"

    local after_files
    after_files=$(find "$NGINX_SSL_DIR" -type f \( -name "*.crt" -o -name "*.pem" -o -name "*.key" \) 2>/dev/null | sort)

    local new_files
    new_files=$(comm -13 <(echo "$before_files") <(echo "$after_files"))

    if [[ -n "$new_files" ]]; then
        blank; hr; blank
        ok "New certificate files detected:"
        echo "$new_files"
        blank
        confirm "Register these in pngxconf DB?" && _cert_register_from_dir
    fi
}

_cert_register_from_dir() {
    section_banner "Register Certificates" "$NGINX_SSL_DIR"
    while IFS= read -r -d '' cfile; do
        [[ "$cfile" == *.key ]] && continue
        local base; base=$(basename "$cfile" | sed -e 's/_fullchain\.pem$//' -e 's/\.crt$//' -e 's/\.pem$//')
        info "Found: ${cfile}"
        local name domain cert key chain
        ask name "Record name" "$base" || continue
        ask domain "Domain covered" "$base" || continue
        cert="$cfile"
        key=""
        for kext in ".key" "_privkey.pem"; do
            local try="$(dirname "$cfile")/${base}${kext}"
            [[ -f "$try" ]] && { key="$try"; break; }
        done
        [[ -z "$key" ]] && { ask_optional key "Key path (Enter to skip)" || true; }
        chain=""
        local tc="$(dirname "$cfile")/${base}_chain.pem"
        [[ -f "$tc" ]] && chain="$tc"
        cert_add "$name" "$domain" "$cert" "$key" "$chain" "ssl-wizard"
        ok "Registered: ${name}"
    done < <(find "$NGINX_SSL_DIR" -maxdepth 3 -type f \( -name "*.crt" -o -name "*fullchain*" \) -print0 2>/dev/null)
    pause
}

_cert_upload() {
    section_banner "Upload Certificate" "Copies to ${NGINX_SSL_DIR}/<domain>/"
    local name domain cert_src key_src chain_src
    ask name "Record name" || return
    ask domain "Domain covered" || return

    # ENFORCE standard layout: /etc/nginx/ssl/<domain>/
    local dest_dir="${NGINX_SSL_DIR}/${domain}"
    mkdir -p "$dest_dir"
    chmod 700 "$dest_dir"

    blank
    ask cert_src "Path to certificate file" || return
    [[ ! -f "$cert_src" ]] && { err_pause "File not found: ${cert_src}"; return; }
    local cert_dest="${dest_dir}/${domain}.crt"
    cp "$cert_src" "$cert_dest" || { err_pause "Failed to copy certificate"; return; }
    chmod 644 "$cert_dest"
    ok "Cert copied to: ${cert_dest}"

    blank
    ask key_src "Path to private key" || return
    [[ ! -f "$key_src" ]] && { err_pause "File not found: ${key_src}"; return; }
    local key_dest="${dest_dir}/${domain}.key"
    cp "$key_src" "$key_dest" || { err_pause "Failed to copy key"; return; }
    chmod 600 "$key_dest"
    ok "Key copied to: ${key_dest}"

    local chain_dest=""
    blank
    ask_optional chain_src "Chain file path (Enter to skip)" || true
    if [[ -n "$chain_src" && -f "$chain_src" ]]; then
        chain_dest="${dest_dir}/${domain}.chain.pem"
        cp "$chain_src" "$chain_dest"
        chmod 644 "$chain_dest"
        ok "Chain copied to: ${chain_dest}"
    fi

    cert_add "$name" "$domain" "$cert_dest" "$key_dest" "$chain_dest" "manual"
    ok "Registered as '${name}'"
    pause
}

_cert_inspect() {
    section_banner "Inspect Certificate" ""
    local rows; rows=$(certs_list)
    [[ -z "$rows" ]] && { info "No certs."; pause; return; }
    local i=1; declare -a names=()
    while IFS='|' read -r name domain _ _ _ _ _; do
        [[ -z "$name" ]] && continue
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${domain})${R}"
        names+=("$name"); (( i++ )) || true
    done <<< "$rows"
    blank; hr; blank
    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"
    local cf; cf=$(cert_get_field "$chosen" 3)
    blank
    if [[ ! -f "$cf" ]]; then
        err_pause "File not found: ${cf}"
    else
        hr
        echo -e "  ${BOLD}Subject:${R}";          openssl x509 -noout -subject -in "$cf" 2>/dev/null; blank
        echo -e "  ${BOLD}Issuer:${R}";           openssl x509 -noout -issuer  -in "$cf" 2>/dev/null; blank
        echo -e "  ${BOLD}Validity:${R}";         openssl x509 -noout -dates   -in "$cf" 2>/dev/null; blank
        echo -e "  ${BOLD}SANs:${R}";             openssl x509 -noout -ext subjectAltName -in "$cf" 2>/dev/null; blank
        echo -e "  ${BOLD}Serial:${R}";           openssl x509 -noout -serial  -in "$cf" 2>/dev/null
        hr
    fi
    pause
}

_certs_check_expiry() {
    section_banner "Certificate Expiry" ""
    local rows; rows=$(certs_list)
    [[ -z "$rows" ]] && { info "No certs."; pause; return; }
    local today; today=$(date +%s)
    while IFS='|' read -r name domain cert _ _ _ _; do
        [[ -z "$name" ]] && continue
        printf "  %-22s %-32s " "$name" "$domain"
        if [[ ! -f "$cert" ]]; then printf "${RED}cert file missing${R}\n"; continue; fi
        local ed; ed=$(openssl x509 -noout -enddate -in "$cert" 2>/dev/null | cut -d= -f2)
        [[ -z "$ed" ]] && { printf "${YELLOW}cannot read${R}\n"; continue; }
        local exp; exp=$(date -d "$ed" +%s 2>/dev/null)
        [[ -z "$exp" ]] && { printf "${YELLOW}cannot parse${R}\n"; continue; }
        local days=$(( (exp - today) / 86400 ))
        if (( days < 0 )); then printf "${RED}EXPIRED %d days ago${R}\n" "$((-days))"
        elif (( days < 30 )); then printf "${YELLOW}%d days left${R}  [%s]\n" "$days" "$ed"
        else printf "${GREEN}%d days left${R}  [%s]\n" "$days" "$ed"; fi
    done <<< "$rows"
    pause
}

_cert_remove() {
    section_banner "Remove Cert Record" ""
    local rows; rows=$(certs_list)
    [[ -z "$rows" ]] && { info "No certs."; pause; return; }
    local i=1; declare -a names=()
    while IFS='|' read -r name domain _ _ _ _ _; do
        [[ -z "$name" ]] && continue
        echo -e "  ${BLUE}  ${i})${R}  ${name}  ${DIM}(${domain})${R}"
        names+=("$name"); (( i++ )) || true
    done <<< "$rows"
    blank; hr; blank
    local c; menu_pick c "${names[@]}" || return
    local chosen="${names[$((c-1))]}"
    confirm "Remove '${chosen}' from DB? (files on disk kept)" || { pause; return; }
    cert_remove "$chosen"; ok "Removed."
    pause
}

# ==============================================================================
#  Status / Control
# ==============================================================================
section_status() {
    section_banner "SYSTEM STATUS" ""
    local nbin; nbin=$(nginx_bin)
    local nver; nver=$(nginx_version)
    local rstr; rstr=$(nginx_is_running && echo "${GREEN}running${R}" || echo "${RED}stopped${R}")
    echo -e "  ${DIM}nginx binary  :${R} ${WHITE}${nbin:-not found}${R}"
    echo -e "  ${DIM}nginx version :${R} ${WHITE}${nver}${R}"
    echo -e "  ${DIM}status        :${R} ${rstr}"
    blank
    echo -e "  ${DIM}nginx.conf    :${R} ${WHITE}${NGINX_CONF}${R}"
    echo -e "  ${DIM}conf.d        :${R} ${WHITE}${NGINX_CONFD}${R}"
    echo -e "  ${DIM}ssl dir       :${R} ${WHITE}${NGINX_SSL_DIR}${R}"
    blank
    echo -e "  ${DIM}sites         :${R} ${WHITE}$(sites_count)${R}"
    echo -e "  ${DIM}certs         :${R} ${WHITE}$(certs_count)${R}"
    local fr; fr=$(state_get "FIRST_RUN_DATE")
    local le; le=$(state_get "NGINX_CONF_LAST_EDIT")
    echo -e "  ${DIM}first run     :${R} ${WHITE}${fr:-never}${R}"
    echo -e "  ${DIM}last conf edit:${R} ${WHITE}${le:-never}${R}"
    blank; hr; blank
    [[ -n "$nbin" ]] && { info "nginx -t:"; blank; nginx_test_quiet || true; }
    pause
}

section_nginx_ctrl() {
    while true; do
        section_banner "nginx Control" ""
        echo -e "  ${BLUE}  1)${R}  Test    (nginx -t)"
        echo -e "  ${BLUE}  2)${R}  Reload"
        echo -e "  ${BLUE}  3)${R}  Restart"
        echo -e "  ${BLUE}  4)${R}  Stop"
        echo -e "  ${BLUE}  5)${R}  Start"
        echo -e "  ${RED}  0)${R}  Back"
        blank; hr; blank
        local c; menu_choice c "Select" 0 5 || return
        case "$c" in
            1) blank; nginx_test_quiet || true; pause ;;
            2) blank
               if nginx_test_quiet &>/dev/null; then
                   nginx_reload && ok "Reloaded" || err_pause "Reload failed"
               else
                   err_pause "Config test failed — NOT reloading"
               fi; pause ;;
            3) confirm "Restart?" && {
                   systemctl restart nginx && ok "Restarted" || err_pause "Restart failed"
               }; pause ;;
            4) confirm "Stop?" && {
                   systemctl stop nginx && ok "Stopped" || err_pause "Stop failed"
               }; pause ;;
            5) systemctl start nginx && ok "Started" || err_pause "Start failed"
               pause ;;
            0) return ;;
        esac
    done
}

# ==============================================================================
#  Main menu
# ==============================================================================
main_menu() {
    while true; do
        banner
        local rstr; rstr=$(nginx_is_running && echo "${GREEN}running${R}" || echo "${RED}stopped${R}")
        local nver; nver=$(state_get "NGINX_VERSION"); [[ -z "$nver" ]] && nver=$(nginx_version)

        echo -e "  ${DIM}nginx ${nver}  │  ${rstr}  ${DIM}│  sites: ${WHITE}$(sites_count)${R}${DIM}  │  certs: ${WHITE}$(certs_count)${R}"
        blank; hr; blank

        echo -e "  ${BOLD}${CYAN}  1)${R}  nginx.conf Management"
        echo -e "  ${BOLD}${CYAN}  2)${R}  Virtual Hosts  ${DIM}(create / edit / delete)${R}"
        echo -e "  ${BOLD}${CYAN}  3)${R}  SSL Certificates  ${DIM}(create / upload / inspect)${R}"
        echo -e "  ${BOLD}${CYAN}  4)${R}  nginx Control  ${DIM}(test / reload / restart)${R}"
        echo -e "  ${BOLD}${CYAN}  5)${R}  System Status"
        echo -e "  ${RED}  0)${R}  Exit"
        blank; hr; blank

        local c; printf "  Select [0-5]: "; IFS= read -r c
        case "$c" in
            1) section_nginx_conf ;;
            2) section_sites ;;
            3) section_certs ;;
            4) section_nginx_ctrl ;;
            5) section_status ;;
            0|q|Q) blank; info "Goodbye."; blank; exit 0 ;;
            *) warn "Invalid choice."; sleep 0.5 ;;
        esac
    done
}

# ==============================================================================
#  Entry point
# ==============================================================================
case "${1:-}" in
    -h|--help) show_help; exit 0 ;;
    "")
        require_root
        state_init
        first_run_check
        startup_check
        main_menu
        ;;
    *)
        err "Unknown argument: $1"
        echo "  Usage: pngxconf  |  pngxconf -h"
        exit 1
        ;;
esac
